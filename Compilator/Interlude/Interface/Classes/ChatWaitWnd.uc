class ChatWaitWnd extends UICommonAPI;

function OnClickButton(string Str)
{
    switch(Str)
    {
        // End:0x1C
        case "btnChat":
            HandleChatBtn();
            // End:0x1F
            break;
        // End:0xFFFF
        default:
            break;
    }
    return;
}

function HandleChatBtn()
{
    ShowWindow("ChatWnd");
    HideWindow("ChatWaitWnd");
    SetOptionBool("Chat", "HideChat", false);
    return;
}