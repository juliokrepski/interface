        {
            Class'UIAPI_WINDOW'.static.HideWindow("TargetStatusWnd.texPledgeCrest");
            Class'UIAPI_WINDOW'.static.MoveTo("TargetStatusWnd.txtPledgeName", rectWnd.nX + 45, rectWnd.nY + 59);
