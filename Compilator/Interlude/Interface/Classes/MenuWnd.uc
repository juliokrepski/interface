function CustomTooltip xxinfotkasi(string zzparamsa)
{
	local CustomTooltip zzToolTip;
	local DrawItemInfo zzdkjuaw2;

	zzToolTip.DrawList.Length = 1;
	zzdkjuaw2.eType = DIT_TEXT;
	zzdkjuaw2.t_strText = zzparamsa;
	zzToolTip.DrawList[0] = zzdkjuaw2;
	return zzToolTip;

}

