class MenuWnd extends UICommonAPI;


var ButtonHandle zzBtnteleportmap;

function OnLoad()
{
    
	zzBtnteleportmap = GetButtonHandle("MenuWnd.BtnTeleport");
	zzBtnteleportmap.SetTooltipCustomType(xxinfotkasi("TeleportWnd"));
	
	
    return;
}

function OnClickButton(string strID)
{
    switch(strID)
    {
        // End:0x20
        case "BtnTeleport":
            ToggleTeleportWnd();
            // End:0xDD
            break;
        // End:0x39
        case "BtnCharInfo":
            ToggleOpenCharInfoWnd();
            // End:0xDD
            break;
        // End:0x53
        case "BtnInventory":
            ToggleOpenInventoryWnd();
            // End:0xDD
            break;
        // End:0x6A
        case "BtnAction":
            ToggleOpenActionWnd();
            // End:0xDD
            break;
        // End:0x80
        case "BtnSkill":
            ToggleOpenMagicSkillWnd();
            // End:0xDD
            break;
        // End:0x96
        case "BtnQuest":
            ToggleOpenQuestWnd();
            // End:0xDD
            break;
        // End:0xAA
        case "BtnMap":
            ToggleOpenMinimapWnd();
            // End:0xDD
            break;
        // End:0xBF
        case "BtnClan":
            ToggleOpenClanWnd();
            // End:0xDD
            break;
        // End:0xDA
        case "BtnSystemMenu":
            ToggleOpenSystemMenuWnd();
            // End:0xDD
            break;
		case "BtnTeleport":
			ToggleTeleportWnd();
            // End:0x14F
			break;	
        // End:0xFFFF
        default:
            break;
    }

}

function ToggleOpenCharInfoWnd()
{
    // End:0x5C
    if(IsShowWindow("DetailStatusWnd"))
    {
        HideWindow("DetailStatusWnd");
        PlaySound("InterfaceSound.charstat_close_01");        
    }
    else
    {
        ShowWindowWithFocus("DetailStatusWnd");
        PlaySound("InterfaceSound.charstat_open_01");
    }
    return;
}

