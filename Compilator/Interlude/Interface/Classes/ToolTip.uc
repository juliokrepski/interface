        m_Info.t_color.B = 121;
        m_Info.t_color.A = byte(255);
        EndItem();
    }
    return;
}

function GetRefineryColor(int Quality, out int R, out int G, out int B)
{
    switch(Quality)
    {
        // End:0x26
        case 1:
            R = 187;
            G = 181;
            B = 138;
            // End:0xA4
            break;
        // End:0x46
        case 2:
            R = 132;
            G = 174;
            B = 216;
            // End:0xA4
            break;
        // End:0x66
        case 3:
            R = 193;
            G = 112;
            B = 202;
            // End:0xA4
            break;
        // End:0x86
        case 4:
            R = 225;
            G = 109;
            B = 109;
            // End:0xA4
            break;
        // End:0xFFFF
        default:
            R = 187;
            G = 181;
            B = 138;
            // End:0xA4
            break;
            break;
    }
    return;
}

