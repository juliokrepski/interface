class ToolTip extends UICommonAPI;

const TOOLTIP_MINIMUM_WIDTH = 174;
const TOOLTIP_SETITEM_MAX = 3;
const TOOLTIP_LINE_HGAP = 4;
const MACROCOMMAND_MAX_COUNT = 12;

var CustomTooltip m_Tooltip;
var DrawItemInfo m_Info;
var int minCard;
var int maxCard;
var int textWidth;
var int textHeight;
var bool BoolSelect;

function OnLoad()
{
    RegisterEvent(2920);
    BoolSelect = false;
    return;
}

function OnEvent(int Event_ID, string param)
{
    switch(Event_ID)
    {
        // End:0x1D
        case 2920:
            HandleRequestTooltipInfo(param);
            // End:0x20
            break;
        // End:0xFFFF
        default:
            break;
    }
    return;
}

function setBoolSelect(bool B)
{
    BoolSelect = B;
    return;
}

function HandleRequestTooltipInfo(string param)
{
    local string TooltipType;
    local int SourceType;
    local ETooltipSourceType eSourceType;

    ClearTooltip();
    if(!ParseString(param, "TooltipType", TooltipType))
    {
        return;
    }

    if(!ParseInt(param, "SourceType", SourceType))
    {
        return;
    }
    
    eSourceType = ETooltipSourceType(SourceType);

    switch (TooltipType)
    {
        case "Text":
            ReturnTooltip_NTT_TEXT(param, eSourceType, false);
            break;
        case "Description":
            ReturnTooltip_NTT_TEXT(param, eSourceType, true);
            break;
        case "Action":
            ReturnTooltip_NTT_ACTION(param, eSourceType);
            break;
        case "Macro":
            ReturnTooltip_NTT_MACRO(param, eSourceType);
            break;
        case "Skill":
            ReturnTooltip_NTT_SKILL(param, eSourceType);
            break;
        case "NormalItem":
            ReturnTooltip_NTT_NORMALITEM(param, eSourceType);
            break;
        case "Shortcut":
            ReturnTooltip_NTT_SHORTCUT(param, eSourceType);
            break;
        case "AbnormalStatus":
            ReturnTooltip_NTT_ABNORMALSTATUS(param, eSourceType);
            break;
        case "RecipeManufacture":
            ReturnTooltip_NTT_RECIPE_MANUFACTURE(param, eSourceType);
            break;
        case "Recipe":
            ReturnTooltip_NTT_RECIPE(param, eSourceType, false);
            break;
        case "RecipePrice":
            ReturnTooltip_NTT_RECIPE(param, eSourceType, true);
            break;
        case "Inventory":
        case "InventoryPrice1":
        case "InventoryPrice2":
        case "InventoryPrice1HideEnchant":
        case "InventoryPrice1HideEnchantStackable":
        case "InventoryPrice2PrivateShop":
            ReturnTooltip_NTT_ITEM(param, TooltipType, eSourceType);
            break;
        case "PartyMatch":
            ReturnTooltip_NTT_PARTYMATCH(param, eSourceType);
            break;
        case "QuestInfo":
            ReturnTooltip_NTT_QUESTINFO(param, eSourceType);
            break;
        case "QuestList":
            ReturnTooltip_NTT_QUESTLIST(param, eSourceType);
            break;
        case "RaidList":
            ReturnTooltip_NTT_RAIDLIST(param, eSourceType);
            break;
        case "ClanInfo":
            ReturnTooltip_NTT_CLANINFO(param, eSourceType);
            break;
        case "ManorSeedInfo":
        case "ManorCropInfo":
        case "ManorSeedSetting":
        case "ManorCropSetting":
        case "ManorDefaultInfo":
        case "ManorCropSell":
            ReturnTooltip_NTT_MANOR(param, TooltipType, eSourceType);
            break;
        default:
            // Aquí puedes manejar casos no contemplados
            break;
    }


}


function bool IsEnchantableItem(EItemParamType Type)
{
    return (((Type == 0) || Type == 1) || Type == 3) || Type == 2;
  
}

function ClearTooltip()
{
    m_Tooltip.SimpleLineCount = 0;
    m_Tooltip.MinimumWidth = 0;
    m_Tooltip.DrawList.Remove(0, m_Tooltip.DrawList.Length);
    return;
}

function StartItem()
{
    local DrawItemInfo infoClear;

    m_Info = infoClear;
    return;
}

function EndItem()
{
    m_Tooltip.DrawList.Length = m_Tooltip.DrawList.Length + 1;
    m_Tooltip.DrawList[m_Tooltip.DrawList.Length - 1] = m_Info;
    return;
}

function ReturnTooltip_NTT_TEXT(string param, ETooltipSourceType eSourceType, bool bDesc)
{
    local string strText;
    local int Id;

    // End:0x156
    if(eSourceType == 0)
    {
        // End:0xFB
        if(ParseString(param, "Text", strText))
        {
            // End:0xF8
            if(Len(strText) > 0)
            {
                // End:0xC2
                if(bDesc)
                {
                    m_Tooltip.MinimumWidth = 174;
                    StartItem();
                    m_Info.eType = DIT_TEXT;
                    m_Info.t_color.R = 178;
                    m_Info.t_color.G = 190;
                    m_Info.t_color.B = 207;
                    m_Info.t_color.A = byte(255);
                    m_Info.t_strText = strText;
                    EndItem();                    
                }
                else
                {
                    StartItem();
                    m_Info.eType = DIT_TEXT;
                    m_Info.t_bDrawOneLine = true;
                    m_Info.t_strText = strText;
                    EndItem();
                }
            }            
        }
        else
        {
            // End:0x153
            if(ParseInt(param, "ID", Id))
            {
                // End:0x153
                if(Id > 0)
                {
                    StartItem();
                    m_Info.eType = DIT_TEXT;
                    m_Info.t_bDrawOneLine = true;
                    m_Info.t_ID = Id;
                    EndItem();
                }
            }
        }        
    }
    else
    {
        return;
    }
    ReturnTooltipInfo(m_Tooltip);
    return;
}

function ReturnTooltip_NTT_ITEM(string param, string TooltipType, ETooltipSourceType eSourceType, optional bool isShortcut)
{
    local ItemInfo item;
    local EItemType EItemType;
    local EEtcItemType EEtcItemType;
    local bool bLargeWidth;
    local string SlotString;
    local int nTmp;
    local string ItemName, ItemSlotWithItemTypeStr, strAdena, strAdenaComma;
    local Color AdenaColor;
    local int nEnchantValueTextGap, nSimpleLineCountAdd, bMainIconGap;

    // End:0x11C4
    if(eSourceType == 1)
    {
        ParamToItemInfo(param, item);
        // End:0x32
        if(item.ClassID < 0)
        {
            return;
        }
        // End:0x50
        if(isShortcut)
        {
            FindItemByServerID(item.ServerID, item);
        }
        EItemType = EItemType(item.ItemType);
        EEtcItemType = EEtcItemType(item.ItemSubType);
        ItemName = Class'UIDATA_ITEM'.static.GetRefineryItemName(item.Name, item.RefineryOp1, item.RefineryOp2);
        // End:0xC7
        if(addItemIcon(item, item.IconName))
        {
            bMainIconGap = 3;
        }
        // End:0x135
        if((TooltipType != "InventoryPrice1HideEnchant") && TooltipType != "InventoryPrice1HideEnchantStackable")
        {
            AddTooltipItemEnchant(item, true, 5, 1);
            nEnchantValueTextGap = 2;
        }
        AddTooltipItemName(ItemName, item, 1, bMainIconGap + nEnchantValueTextGap, 1);
        GetTextSize((((" + Augmented " $ string(item.Enchanted)) $ ItemName) $ " ") $ item.AdditionalName, textWidth, textHeight);
        AddTooltipItemGrade(item, 0, 1);
        // End:0x208
        if(TooltipType != "InventoryPrice1HideEnchantStackable")
        {
            // End:0x208
            if(TooltipType != "QuestReward")
            {
                // End:0x208
                if(item.ItemNum > 0)
                {
                    AddTooltipItemCount(item, 0, 1);
                }
            }
        }
        ItemSlotWithItemTypeStr = getSlotTypeWithItemTypeString(item);
        // End:0x265
        if(ItemSlotWithItemTypeStr != "")
        {
            m_Tooltip.SimpleLineCount = 2 + nSimpleLineCountAdd;
            AddTooltipItemBlank(1);
            AddTooltipColorText(ItemSlotWithItemTypeStr, GetColorXA(176, 155, 121, 255), false, true, false, "", 40, -17);
        }
        // End:0x2AE
        if(item.ClassID == 57)
        {
            m_Tooltip.SimpleLineCount = 3 + nSimpleLineCountAdd;
            AddTooltipText(("(" $ ConvertNumToText(string(item.ItemNum))) $ ")", true, true);
        }
        // End:0x4B2
        if((TooltipType == "InventoryStackableUnitPrice") && !item.bEquipped)
        {
            strAdena = string(item.Price);
            strAdenaComma = MakeCostString(strAdena);
            AdenaColor = GetNumericColor(strAdenaComma);
            // End:0x399
            if(IsStackableItem(item.ConsumeType) && item.ItemNum > 1)
            {
                AddTooltipItemBlank(4);
                AddTooltipColorText("Unit Price : ", GetColorXA(255, 180, 0, 255), true, true, false);
                AddTooltipColorText((strAdenaComma $ " ") $ GetSystemString(469), AdenaColor, false, true,, "", 0, 0);                
            }
            else
            {
                AddTooltipItemOption(322, (strAdenaComma $ " ") $ GetSystemString(469), true, true, false,,,, AdenaColor);
            }
            // End:0x458
            if(IsStackableItem(item.ConsumeType) && item.ItemNum > 1)
            {
                strAdena = string(item.Price * item.ItemNum);
                strAdenaComma = MakeCostString(strAdena);
                AdenaColor = GetNumericColor(strAdenaComma);
                AddTooltipItemOption(2595, (strAdenaComma $ " ") $ GetSystemString(469), true, true, false,,,, AdenaColor);
            }
            // End:0x4B2
            if(item.Price > 0)
            {
                AddTooltipItemOption(0, ("(" $ ConvertNumToText(strAdena)) $ ")", false, true, false);
                SetTooltipItemColor(AdenaColor.R, AdenaColor.G, AdenaColor.B, 0);
            }
        }
        // End:0x613
        if((((TooltipType == "InventoryPrice1") || TooltipType == "InventoryPrice1HideEnchant") || TooltipType == "InventoryPrice1HideEnchantStackable") && !item.bEquipped)
        {
            strAdena = string(item.Price);
            strAdenaComma = MakeCostString(strAdena);
            AdenaColor = GetNumericColor(strAdenaComma);
            AddTooltipItemOption(322, (strAdenaComma $ " ") $ GetSystemString(469), true, true, false);
            m_Tooltip.SimpleLineCount = 3 + nSimpleLineCountAdd;
            // End:0x613
            if(item.Price > 0)
            {
                m_Tooltip.SimpleLineCount = 4 + nSimpleLineCountAdd;
                AddTooltipItemOption(0, ("(" $ ConvertNumToText(strAdena)) $ ")", false, true, false);
                SetTooltipItemColor(AdenaColor.R, AdenaColor.G, AdenaColor.B, 0);
            }
        }
        // End:0x778
        if((TooltipType == "InventoryPrice2") || TooltipType == "InventoryPrice2PrivateShop")
        {
            strAdena = string(item.Price);
            strAdenaComma = MakeCostString(strAdena);
            AdenaColor = GetNumericColor(strAdenaComma);
            AddTooltipItemOption2(322, 468, true, true, false);
            SetTooltipItemColor(AdenaColor.R, AdenaColor.G, AdenaColor.B, 0);
            AddTooltipColorText(((" " $ strAdenaComma) $ " ") $ GetSystemString(469), AdenaColor, false, true,,,, 4);
            m_Tooltip.SimpleLineCount = 3 + nSimpleLineCountAdd;
            // End:0x778
            if(item.Price > 0)
            {
                m_Tooltip.SimpleLineCount = 4 + nSimpleLineCountAdd;
                AddTooltipColorText("(", AdenaColor, true, true);
                AddTooltipColorText(GetSystemString(468), AdenaColor, false, true);
                AddTooltipColorText((" " $ ConvertNumToText(strAdena)) $ ")", AdenaColor, false, true);
            }
        }
        // End:0x7DD
        if(TooltipType == "InventoryPrice2PrivateShop")
        {
            // End:0x7DD
            if(IsStackableItem(item.ConsumeType) && item.Reserved > 0)
            {
                AddTooltipItemOption(808, string(item.Reserved), true, true, false);
            }
        }
        SlotString = "";
        SlotString = GetSlotTypeString(item.ItemType, item.SlotBitType, item.ArmorType);
        switch(EItemType)
        {
            // End:0xB19
            case ITEM_WEAPON:
                bLargeWidth = true;
                // End:0x8F0
                if(item.PhysicalDamage != 0)
                {
                    AddTooltipItemOption(94, string(GetPhysicalDamage(item.WeaponType, item.SlotBitType, item.CrystalType, item.Enchanted, item.PhysicalDamage)), true, true, false, 2, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                    AddTooltipItemBonus(item.PhysicalDamage, GetPhysicalDamage(item.WeaponType, item.SlotBitType, item.CrystalType, item.Enchanted, item.PhysicalDamage) - item.PhysicalDamage, 0, 4);
                }
                // End:0x9BD
                if(item.MagicalDamage != 0)
                {
                    AddTooltipItemOption(98, string(GetPhysicalDamage(item.WeaponType, item.SlotBitType, item.CrystalType, item.Enchanted, item.MagicalDamage)), true, true, false, 2, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                    AddTooltipItemBonus(item.MagicalDamage, GetMagicalDamage(item.WeaponType, item.SlotBitType, item.CrystalType, item.Enchanted, item.MagicalDamage) - item.MagicalDamage, 0, 4);
                }
                AddTooltipItemOption(111, GetAttackSpeedString(item.AttackSpeed), true, true, false);
                // End:0xA1F
                if(item.ShieldDefense > 0)
                {
                    AddTooltipItemOption(95, string(item.ShieldDefense), true, true, false, 0, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                }
                // End:0xA49
                if(item.ShieldDefenseRate > 0)
                {
                    AddTooltipItemOption(317, string(item.ShieldDefenseRate), true, true, false);
                }
                // End:0xA78
                if(item.SoulshotCount > 0)
                {
                    AddTooltipItemOption(404, "X" $ string(item.SoulshotCount), true, true, false);
                }
                // End:0xAA7
                if(item.SpiritshotCount > 0)
                {
                    AddTooltipItemOption(496, "X" $ string(item.SpiritshotCount), true, true, false);
                }
                // End:0xACA
                if(item.Weight == 0)
                {
                    AddTooltipItemOption(52, " 0 ", true, true, false);                    
                }
                else
                {
                    AddTooltipItemOption(52, string(item.Weight), true, true, false);
                }
                // End:0xB0B
                if(item.MpConsume != 0)
                {
                    AddTooltipItemOption(320, string(item.MpConsume), true, true, false);
                }
                AddTooltipRefinery(item);
                // End:0x11A0
                break;
            // End:0xE58
            case ITEM_ARMOR:
                bLargeWidth = true;
                // End:0xC56
                if((item.SlotBitType == 256) || item.SlotBitType == 128)
                {
                    // End:0xBF2
                    if(item.ShieldDefense != 0)
                    {
                        AddTooltipItemOption(95, string(GetShieldDefense(item.CrystalType, item.Enchanted, item.ShieldDefense)), true, true, false, 2, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                        AddTooltipItemBonus(item.ShieldDefense, GetShieldDefense(item.CrystalType, item.Enchanted, item.ShieldDefense) - item.ShieldDefense, 0, 4);
                    }
                    // End:0xC1F
                    if(item.ShieldDefenseRate > 0)
                    {
                        AddTooltipItemOption(317, string(item.ShieldDefenseRate), true, true, false, 2, 0);
                    }
                    AddTooltipItemOption(97, string(item.AvoidModify), true, true, false, 2, 0);
                    AddTooltipItemOption(52, string(item.Weight), true, true, false, 2, 0);                    
                }
                else
                {
                    // End:0xD86
                    if(IsMagicalArmor(item.ClassID))
                    {
                        // End:0xCB4
                        if(item.MpBonus > 0)
                        {
                            AddTooltipItemOption(388, string(item.MpBonus), true, true, false, 2, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                        }
                        // End:0xD59
                        if(item.PhysicalDefense != 0)
                        {
                            AddTooltipItemOption(95, string(GetPhysicalDefense(item.CrystalType, item.Enchanted, item.PhysicalDefense)), true, true, false, 2, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                            AddTooltipItemBonus(item.PhysicalDefense, GetPhysicalDefense(item.CrystalType, item.Enchanted, item.PhysicalDefense) - item.PhysicalDefense, 0, 4);
                        }
                        // End:0xD83
                        if(item.Weight != 0)
                        {
                            AddTooltipItemOption(52, string(item.Weight), true, true, false, 2, 0);
                        }                        
                    }
                    else
                    {
                        // End:0xE2B
                        if(item.PhysicalDefense != 0)
                        {
                            AddTooltipItemOption(95, string(GetPhysicalDefense(item.CrystalType, item.Enchanted, item.PhysicalDefense)), true, true, false, 2, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                            AddTooltipItemBonus(item.PhysicalDefense, GetPhysicalDefense(item.CrystalType, item.Enchanted, item.PhysicalDefense) - item.PhysicalDefense, 0, 4);
                        }
                        // End:0xE55
                        if(item.Weight != 0)
                        {
                            AddTooltipItemOption(52, string(item.Weight), true, true, false, 2, 0);
                        }
                    }
                }
                // End:0x11A0
                break;
            // End:0xFAB
            case ITEM_ACCESSARY:
                bLargeWidth = true;
                // End:0xF63
                if(((item.SlotBitType != 4194304) && item.SlotBitType != 1048576) && item.SlotBitType != 2097152)
                {
                    // End:0xF20
                    if(GetMagicalDefense(item.CrystalType, item.Enchanted, item.MagicalDefense) > 0)
                    {
                        AddTooltipItemOption(99, string(GetMagicalDefense(item.CrystalType, item.Enchanted, item.MagicalDefense)), true, true, false, 0, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
                    }
                    AddTooltipItemBonus(item.MagicalDefense, GetPhysicalDefense(item.CrystalType, item.Enchanted, item.MagicalDefense) - item.MagicalDefense, 0, 4);
                }
                // End:0xF86
                if(item.Weight == 0)
                {
                    AddTooltipItemOption(52, " 0 ", true, true, false);                    
                }
                else
                {
                    AddTooltipItemOption(52, string(item.Weight), true, true, false);
                }
                AddTooltipRefinery(item);
                // End:0x11A0
                break;
            // End:0xFCF
            case ITEM_ETCITEM:
                // End:0xFCC
                if(Len(SlotString) > 0)
                {
                    AddTooltipItemOption(0, SlotString, false, true, false);
                }
                // End:0x11A0
                break;
            // End:0x119D
            case EItemType(5):
                bLargeWidth = true;
                // End:0x1042
                if(EEtcItemType == 7)
                {
                    // End:0x100A
                    if(item.Damaged == 0)
                    {
                        nTmp = 971;                        
                    }
                    else
                    {
                        nTmp = 970;
                    }
                    AddTooltipItemOption2(969, nTmp, true, true, false);
                    AddTooltipItemOption(88, string(item.Enchanted), true, true, false);                    
                }
                else
                {
                    // End:0x106F
                    if(EEtcItemType == 15)
                    {
                        AddTooltipItemOption(972, string(item.Enchanted), true, true, false);                        
                    }
                    else
                    {
                        // End:0x10C4
                        if(EEtcItemType == 13)
                        {
                            AddTooltipItemOption(670, string(item.Blessed), true, true, false);
                            AddTooltipItemOption(671, GetLottoString(item.Enchanted, item.Damaged), true, true, false);                            
                        }
                        else
                        {
                            // End:0x112A
                            if(EEtcItemType == 14)
                            {
                                AddTooltipItemOption(670, string(item.Enchanted), true, true, false);
                                AddTooltipItemOption(671, GetRaceTicketString(item.Blessed), true, true, false);
                                AddTooltipItemOption(744, string(item.Damaged * 100), true, true, false);
                            }
                        }
                    }
                }
                // End:0x114D
                if(item.Weight == 0)
                {
                    AddTooltipItemOption(52, " 0 ", true, true, false);                    
                }
                else
                {
                    // End:0x1183
                    if(item.ItemNum > 1)
                    {
                        AddTooltipItemOption(52, string(item.Weight * item.ItemNum), true, true, false);                        
                    }
                    else
                    {
                        AddTooltipItemOption(52, string(item.Weight), true, true, false);
                    }
                }
                // End:0x11A0
                break;
            // End:0xFFFF
            default:
                break;
        }
        AddTooltipItemDurability(item);
        addDescTooltip(item);
        addSetitemTooltip(item);        
    }
    else
    {
        return;
    }
    // End:0x11DC
    if(bLargeWidth)
    {
        m_Tooltip.MinimumWidth = 174;
    }
    ReturnTooltipInfo(m_Tooltip);
    return;
}

function ReturnTooltip_NTT_ACTION(string param, ETooltipSourceType eSourceType)
{
    local ItemInfo item;

    // End:0x14A
    if(eSourceType == 1)
    {
        ParamToItemInfo(param, item);
        addItemIcon(item, "");
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.nOffSetX = 5;
        m_Info.nOffSetY = 0;
        m_Info.t_strText = item.Name;
        EndItem();
        AddTooltipItemBlank(4);
        // End:0x147
        if(Len(item.Description) > 0)
        {
            m_Tooltip.MinimumWidth = 174;
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.nOffSetY = 4;
            m_Info.t_bDrawOneLine = false;
            m_Info.bLineBreak = true;
            m_Info.t_color.R = 178;
            m_Info.t_color.G = 190;
            m_Info.t_color.B = 207;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = item.Description;
            EndItem();
        }        
    }
    else
    {
        return;
    }
    ReturnTooltipInfo(m_Tooltip);
    return;
}

function ReturnTooltip_NTT_SKILL(string param, ETooltipSourceType eSourceType)
{
    local ItemInfo item;
    local EItemParamType EItemParamType;
    local int nTmp, SkillLevel;
    local SkillInfo SkillInfo;

    // End:0x560
    if(eSourceType == 1)
    {
        ParseString(param, "Name", item.Name);
        ParseString(param, "AdditionalName", item.AdditionalName);
        ParseString(param, "Description", item.Description);
        ParseInt(param, "ClassID", item.ClassID);
        ParseInt(param, "Level", item.Level);
        GetSkillInfo(item.ClassID, item.Level, SkillInfo);
        item.IconName = Class'UIDATA_SKILL'.static.GetIconName(item.ClassID, item.Level);
        EItemParamType = EItemParamType(item.ItemType);
        SkillLevel = item.Level;
        m_Tooltip.MinimumWidth = 174;
        addItemIcon(item, "");
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.nOffSetX = 5;
        m_Info.t_strText = item.Name;
        EndItem();
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.t_strText = " ";
        EndItem();
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.t_color.R = 163;
        m_Info.t_color.G = 163;
        m_Info.t_color.B = 163;
        m_Info.t_color.A = byte(255);
        m_Info.t_ID = 88;
        EndItem();
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.t_color.R = 176;
        m_Info.t_color.G = 155;
        m_Info.t_color.B = 121;
        m_Info.t_color.A = byte(255);
        m_Info.t_strText = " " $ string(SkillLevel);
        EndItem();
        // End:0x35B
        if(Len(item.AdditionalName) > 0)
        {
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.nOffSetX = 5;
            m_Info.t_bDrawOneLine = true;
            m_Info.t_color.R = byte(255);
            m_Info.t_color.G = 217;
            m_Info.t_color.B = 105;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = item.AdditionalName;
            EndItem();
        }
        AddTooltipItemBlank(1);
        AddTooltipColorText(Class'UIDATA_SKILL'.static.GetOperateType(item.ClassID, item.Level), GetColorXA(176, 155, 121, 255), true, true, false, "", 38, -19);
        nTmp = Class'UIDATA_SKILL'.static.GetHpConsume(item.ClassID, item.Level);
        // End:0x3EE
        if(nTmp > 0)
        {
            AddTooltipItemOption(1195, string(nTmp), true, true, false);
        }
        nTmp = Class'UIDATA_SKILL'.static.GetMpConsume(item.ClassID, item.Level);
        // End:0x457
        if(nTmp > 0)
        {
            AddTooltipItemOption(320, string(nTmp), true, true, false, 0, 0, xxgetInstanceL2Util().BrightWhite, xxgetInstanceL2Util().ColorYellow);
        }
        nTmp = Class'UIDATA_SKILL'.static.GetCastRange(item.ClassID, item.Level);
        // End:0x4A0
        if(nTmp >= 0)
        {
            AddTooltipItemOption(321, string(nTmp), true, true, false);
        }
        // End:0x4D8
        if(Len(item.Description) > 0)
        {
            AddCrossLine();
            AddTooltipColorText(item.Description, GetColorXA(178, 190, 207, 255), true, false);
        }
        // End:0x55D
        if(Len(item.AdditionalName) > 0)
        {
            AddCrossLine();
            AddTooltipColorText("Enchantment Effect : ", GetColorXA(163, 163, 163, 255), true, false);
            AddTooltipColorText(item.AdditionalName, GetColorXA(255, 217, 105, 255), false, true);
            AddTooltipColorText(SkillInfo.EnchantDesc, GetColorXA(178, 190, 207, 255), true, false);
        }        
    }
    else
    {
        return;
    }
    ReturnTooltipInfo(m_Tooltip);
    return;
}

function ReturnTooltip_NTT_ABNORMALSTATUS(string param, ETooltipSourceType eSourceType)
{
    local ItemInfo item;
    local SkillInfo SkillInfo;
    local int ShowLevel;
    local EItemParamType EItemParamType;

    // End:0x6DF
    if(eSourceType == 1)
    {
        ParseInt(param, "ClassID", item.ClassID);
        ParseString(param, "Name", item.Name);
        ParseString(param, "AdditionalName", item.AdditionalName);
        ParseString(param, "Description", item.Description);
        ParseInt(param, "Level", item.Level);
        ParseInt(param, "Reserved", item.Reserved);
        // End:0xFB
        if(item.ClassID > 1000000)
        {
            item.ClassID = item.ClassID - 1000000;
        }
        EItemParamType = EItemParamType(item.ItemType);
        GetSkillInfo(item.ClassID, item.Level, SkillInfo);
        item.IconName = Class'UIDATA_SKILL'.static.GetIconName(item.ClassID, item.Level);
        m_Tooltip.MinimumWidth = 174;
        addItemIcon(item, "");
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.nOffSetX = 5;
        m_Info.t_strText = item.Name;
        EndItem();
        ShowLevel = item.Level;
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.t_strText = " ";
        EndItem();
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.t_color.R = 163;
        m_Info.t_color.G = 163;
        m_Info.t_color.B = 163;
        m_Info.t_color.A = byte(255);
        m_Info.t_ID = 88;
        EndItem();
        StartItem();
        m_Info.eType = DIT_TEXT;
        m_Info.t_bDrawOneLine = true;
        m_Info.t_color.R = 176;
        m_Info.t_color.G = 155;
        m_Info.t_color.B = 121;
        m_Info.t_color.A = byte(255);
        m_Info.t_strText = " " $ string(ShowLevel);
        EndItem();
        // End:0x3AA
        if(Len(item.AdditionalName) > 0)
        {
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.nOffSetX = 5;
            m_Info.t_bDrawOneLine = true;
            m_Info.t_color.R = byte(255);
            m_Info.t_color.G = 217;
            m_Info.t_color.B = 105;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = item.AdditionalName;
            EndItem();
        }
        // End:0x5B3
        if(item.Reserved >= 0)
        {
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.bLineBreak = true;
            m_Info.t_bDrawOneLine = true;
            m_Info.nOffSetX = 39;
            m_Info.nOffSetY = -15;
            m_Info.t_color.R = 163;
            m_Info.t_color.G = 163;
            m_Info.t_color.B = 163;
            m_Info.t_color.A = byte(255);
            m_Info.t_ID = 1199;
            EndItem();
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.t_bDrawOneLine = true;
            m_Info.nOffSetY = -15;
            m_Info.t_color.R = 163;
            m_Info.t_color.G = 163;
            m_Info.t_color.B = 163;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = " : ";
            EndItem();
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.t_bDrawOneLine = true;
            m_Info.nOffSetY = -15;
            m_Info.t_color.R = byte(255);
            m_Info.t_color.G = 221;
            m_Info.t_color.B = 102;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = MakeBuffTimeStr(item.Reserved);
            ParamAdd(m_Info.Condition, "Type", "RemainTime");
            EndItem();
        }
        // End:0x657
        if(Len(item.Description) > 0)
        {
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.nOffSetY = 4;
            m_Info.bLineBreak = true;
            m_Info.t_color.R = 178;
            m_Info.t_color.G = 190;
            m_Info.t_color.B = 207;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = item.Description;
            EndItem();
        }
        // End:0x6DC
        if(Len(item.AdditionalName) > 0)
        {
            AddCrossLine();
            AddTooltipColorText("Enchantment Effect : ", GetColorXA(163, 163, 163, 255), true, false);
            AddTooltipColorText(item.AdditionalName, GetColorXA(255, 217, 105, 255), false, true);
            AddTooltipColorText(SkillInfo.EnchantDesc, GetColorXA(178, 190, 207, 255), true, false);
        }        
    }
    else
    {
        return;
    }
    ReturnTooltipInfo(m_Tooltip);
    return;
}

