function AddCrossLine(optional int minimum_width)
{
    AddTooltipItemBlank(2);
    StartItem();
    m_Info.eType = DIT_TEXTURE;
    // End:0x39
    if(minimum_width > 0)
    {
        m_Info.u_nTextureWidth = minimum_width;        
    }
    else
    {
        m_Info.u_nTextureWidth = getMaxWidth();
    }
    m_Info.u_nTextureHeight = 1;
    m_Info.u_strTexture = "L2ui_ch3.tooltip_line";
    EndItem();
    AddTooltipItemBlank(4);
    return;
}

function ReturnTooltip_NTT_MACRO(string param, ETooltipSourceType eSourceType, optional bool bUseUserMacro)
{
    local ItemInfo item;
    local MacroInfo MacroInfo;
    local int idx;
    local array<string> commandArray;
    local bool bCustomMacro;

    // End:0x18B
    if(eSourceType == 1)
    {
        ParamToItemInfo(param, item);
        bCustomMacro = Class'UIDATA_MACRO'.static.GetMacroInfo(item.ClassID, MacroInfo);
        // End:0x56
        if(MacroInfo.IconTextureName != "")
        {
        }
        addItemIcon(item, "");
        m_Tooltip.MinimumWidth = 174;
        AddTooltipText(item.Name, false, true, true, 5, 1);
        AddTooltipItemBlank(2);
        // End:0x120
        if((item.MacroCommand != "") && !bUseUserMacro)
        {
            Split(item.MacroCommand, "n", commandArray);
            idx = 0;
            J0xCB:

            // End:0x11D [Loop If]
            if(idx < commandArray.Length)
            {
                // End:0x113
                if(commandArray[idx] != "")
                {
                    AddTooltipColorText(commandArray[idx], GetColorXA(176, 155, 121, 255), true, true,, "", 2);
                }
                idx++;
                // [Loop Continue]
                goto J0xCB;
            }            
        }
        else
        {
            // End:0x188
            if(bCustomMacro)
            {
                idx = 0;
                J0x130:

                // End:0x188 [Loop If]
                if(idx < 12)
                {
                    // End:0x17E
                    if(MacroInfo.CommandList[idx] != "")
                    {
                        AddTooltipColorText(MacroInfo.CommandList[idx], GetColorXA(176, 155, 121, 255), true, true,, "", 2);
                    }
                    idx++;
                    // [Loop Continue]
                    goto J0x130;
                }
            }
        }        
    }
    else
    {
        return;
    }
    ReturnTooltipInfo(m_Tooltip);
    return;
}

function addTooltipID(ItemInfo item)
{
    AddCrossLine();
    AddTooltipColorText((("ClassID: " $ string(item.ClassID)) $ " | ServerID: ") $ string(item.ServerID), GetColorXA(176, 155, 121, 255), true, true,, "", 2);
    return;
}

function bool addItemIcon(ItemInfo item, string ForeTexture)
{
    // End:0x13
    if(item.IconName == "")
    {
        return false;
    }
    StartItem();
    m_Info.eType = DIT_TEXTURE;
    m_Info.u_nTextureWidth = 35;
    m_Info.u_nTextureHeight = 35;
    m_Info.u_nTextureUWidth = 35;
    m_Info.u_nTextureUHeight = 35;
    m_Info.u_strTexture = "L2UI_CH3.Tooltip.SlotBox_Default";
    EndItem();
    StartItem();
    m_Info.eType = DIT_TEXTURE;
    m_Info.u_nTextureWidth = 32;
    m_Info.u_nTextureHeight = 32;
    m_Info.u_nTextureUWidth = 32;
    m_Info.u_nTextureUHeight = 32;
    m_Info.nOffSetX = -33;
    m_Info.nOffSetY = 1;
    m_Info.u_strTexture = item.IconName;
    EndItem();
    // End:0x287
    if((item.Enchanted > 0) || item.ItemNum > 1)
    {
        StartItem();
        m_Info.eType = DIT_TEXTURE;
        m_Info.u_nTextureWidth = 32;
        m_Info.u_nTextureHeight = 32;
        m_Info.u_nTextureUWidth = 32;
        m_Info.u_nTextureUHeight = 32;
        m_Info.nOffSetX = -32;
        m_Info.nOffSetY = 1;
        // End:0x1FC
        if(((item.Enchanted <= 50) && item.Enchanted > 0) && item.SlotBitType > 0)
        {
            m_Info.u_strTexture = "L2UI_CH3.ItemEnchant.enchant" $ string(item.Enchanted);
        }
        // End:0x281
        if(item.ItemNum > 1)
        {
            // End:0x24B
            if(item.ItemNum > 99)
            {
                m_Info.u_strTexture = "L2UI_CH3.ItemCount.texCount99+";                
            }
            else
            {
                m_Info.u_strTexture = "L2UI_CH3.ItemCount.texCount" $ string(item.ItemNum);
            }
        }
        EndItem();
    }
    return true;

}

function AddTooltipText(string strDesc, bool bLineBreak, bool t_bDrawOneLine, optional bool isFirstLine, optional int offsetX, optional int offsetY)
{
    StartItem();
    m_Info.eType = DIT_TEXT;
    // End:0x2B
    if(!isFirstLine)
    {
        m_Info.nOffSetY = 4;
    }
    m_Info.nOffSetX = m_Info.nOffSetX + offsetX;
    m_Info.nOffSetY = m_Info.nOffSetY + offsetY;
    m_Info.t_strText = strDesc;
    m_Info.bLineBreak = bLineBreak;
    m_Info.t_bDrawOneLine = t_bDrawOneLine;
    EndItem();
    return;
}

function AddTooltipColorText(string strDesc, Color TextColor, bool bLineBreak, bool t_bDrawOneLine, optional bool isFirstLine, optional string FontName, optional int offsetX, optional int offsetY)
{
    StartItem();
    m_Info.eType = DIT_TEXT;
    // End:0x2B
    if(!isFirstLine)
    {
        m_Info.nOffSetY = 4;
    }
    m_Info.bLineBreak = bLineBreak;
    m_Info.t_bDrawOneLine = t_bDrawOneLine;
    m_Info.nOffSetX = m_Info.nOffSetX + offsetX;
    m_Info.nOffSetY = m_Info.nOffSetY + offsetY;
    m_Info.t_color = TextColor;
    m_Info.t_strText = strDesc;
    m_Info.nOffSetX = offsetX;
    m_Info.nOffSetY = offsetY;
    EndItem();
    return;
}

function int getMaxWidth()
{
    local int tmp;

    tmp = textWidth + 10;
    // End:0x23
    if(tmp < 174)
    {
        tmp = 174;
    }
    return tmp;

}

function AddTooltipItemBonus(int nBasic, int nBonus, optional int offsetX, optional int offsetY)
{
    // End:0x95
    if(nBonus > 0)
    {
        AddTooltipColorText((" (" $ string(nBasic)) $ " ", GetColorXA(176, 155, 121, 255), false, true, false, "", offsetX, offsetY);
        AddTooltipColorText("+" $ string(nBonus), GetColorXA(238, 170, 34, 255), false, true, false, "", offsetX, offsetY);
        AddTooltipColorText(")", GetColorXA(176, 155, 121, 255), false, true, false, "", offsetX, offsetY);
    }
    return;
}

function AddTooltipRefinery(ItemInfo item)
{
    local string strDesc1, strDesc2, strDesc3;
    local int ColorR, ColorG, ColorB, Quality;

    // End:0x343
    if((item.RefineryOp1 != 0) || item.RefineryOp2 != 0)
    {
        AddTooltipItemBlank(4);
        AddTitleIconWithHeadLine("LifeBG", Mid(GetSystemString(1490), 1, Len(GetSystemString(1490)) - 2), "");
        // End:0xA9
        if(item.SlotBitType == 8192)
        {
            Quality = Class'UIDATA_REFINERYOPTION'.static.GetQuality(item.RefineryOp1);
            GetRefineryColor(Quality, ColorR, ColorG, ColorB);            
        }
        else
        {
            Quality = Class'UIDATA_REFINERYOPTION'.static.GetQuality(item.RefineryOp2);
            GetRefineryColor(Quality, ColorR, ColorG, ColorB);
        }
        // End:0x1CB
        if(item.RefineryOp1 != 0)
        {
            strDesc1 = "";
            strDesc2 = "";
            strDesc3 = "";
            // End:0x1CB
            if(Class'UIDATA_REFINERYOPTION'.static.GetOptionDescription(item.RefineryOp1, strDesc1, strDesc2, strDesc3))
            {
                // End:0x167
                if(Len(strDesc1) > 0)
                {
                    AddTooltipColorText(strDesc1, GetColorXA(ColorR, ColorG, ColorB, 255), true, false, false);
                }
                // End:0x199
                if(Len(strDesc2) > 0)
                {
                    AddTooltipColorText(strDesc2, GetColorXA(ColorR, ColorG, ColorB, 255), true, false, false);
                }
                // End:0x1CB
                if(Len(strDesc3) > 0)
                {
                    AddTooltipColorText(strDesc3, GetColorXA(ColorR, ColorG, ColorB, 255), true, false, false);
                }
            }
        }
        // End:0x218
        if(item.SlotBitType == 8192)
        {
            Quality = Class'UIDATA_REFINERYOPTION'.static.GetQuality(item.RefineryOp2);
            GetRefineryColor(Quality, ColorR, ColorG, ColorB);
        }
        // End:0x301
        if(item.RefineryOp2 != 0)
        {
            strDesc1 = "";
            strDesc2 = "";
            strDesc3 = "";
            // End:0x301
            if(Class'UIDATA_REFINERYOPTION'.static.GetOptionDescription(item.RefineryOp2, strDesc1, strDesc2, strDesc3))
            {
                // End:0x29D
                if(Len(strDesc1) > 0)
                {
                    AddTooltipColorText(strDesc1, GetColorXA(ColorR, ColorG, ColorB, 255), true, false, false);
                }
                // End:0x2CF
                if(Len(strDesc2) > 0)
                {
                    AddTooltipColorText(strDesc2, GetColorXA(ColorR, ColorG, ColorB, 255), true, false, false);
                }
                // End:0x301
                if(Len(strDesc3) > 0)
                {
                    AddTooltipColorText(strDesc3, GetColorXA(ColorR, ColorG, ColorB, 255), true, false, false);
                }
            }
        }
        // End:0x33B
        if(item.SlotBitType != 8192)
        {
            AddTooltipItemOption(1491, "", true, false, false);
            SetTooltipItemColor(ColorR, ColorG, ColorB, 0);
        }
        AddTooltipItemBlank(2);
    }
    return;
}

function string getSlotTypeWithItemTypeString(ItemInfo item)
{
    local string SlotString, strTmp;
    local EItemType EItemType;

    EItemType = EItemType(item.ItemType);
    SlotString = GetSlotTypeString(item.ItemType, item.SlotBitType, item.ArmorType);
    // End:0x88
    if(EItemType == 0)
    {
        strTmp = GetWeaponTypeString(item.WeaponType);
        // End:0x88
        if(Len(strTmp) > 0)
        {
            SlotString = (strTmp $ " / ") $ SlotString;
        }
    }
    return SlotString;
  
}

function AddTooltipItemDurability(ItemInfo item)
{
    local Color tempColor;

    // End:0xDE
    if((item.CurrentDurability >= 0) && item.Durability > 0)
    {
        AddTooltipItemBlank(4);
        AddTooltipItemOption(1492, "", true, false, false);
        SetTooltipItemColor(255, 255, 255, 0);
        AddTooltipColorText(GetSystemString(1493), GetColorXA(163, 163, 163, 255), true, true);
        // End:0x91
        if((item.CurrentDurability + 1) <= 5)
        {
            tempColor = GetColorXA(255, 0, 0, 255);            
        }
        else
        {
            tempColor = GetColorXA(176, 155, 121, 255);
        }
        AddTooltipColorText(((" " $ string(item.CurrentDurability)) $ "/") $ string(item.Durability), tempColor, false, true);
        AddTooltipItemBlank(4);
    }
    return;
}

function addDescTooltip(ItemInfo item)
{
    local string tmp;
    local array<int> arrID;

    Class'UIDATA_ITEM'.static.GetSetItemIDList(item.ClassID, 0, arrID);
    // End:0x51
    if(arrID[0] > 0)
    {
        AddTooltipItemBlank(4);
        AddTitleIconWithHeadLine("setBG", "Armor Set", "");        
    }
    else
    {
        // End:0x128
        if(Mid(item.Description, 0, 5) == "<Soul")
        {
            AddTooltipItemBlank(4);
            AddTitleIconWithHeadLine("SaBG", "Special Ability: ", item.AdditionalName);
            // End:0xDE
            if(InStr(Left(item.Description, 30), "\\n") > 0)
            {
                tmp = Replace(Mid(item.Description, 29), ". I", "\\nI");                
            }
            else
            {
                tmp = Replace(Mid(item.Description, 27), ". I", "\\nI");
            }
            AddTooltipItemBlank(4);
            AddTooltipColorText(tmp, GetColorXA(110, 140, 160, 255), true, false);            
        }
        else
        {
            // End:0x160
            if(Len(item.Description) > 1)
            {
                AddCrossLine();
                AddTooltipColorText(item.Description, GetColorXA(178, 190, 207, 255), true, false);
            }
        }
    }
    return;
}

function addSetitemTooltip(ItemInfo item)
{
    local int idx;
    local string strTmp;
    local int ClassID, SetID;
    local array<int> arrID;
    local bool bLargeWidth;

    // End:0x6AC
    if(item.ClassID > 0)
    {
        AddTooltipItemBlank(3);
        idx = 0;
        J0x1F:

        // End:0x51C [Loop If]
        if(idx < 3)
        {
            Class'UIDATA_ITEM'.static.GetSetItemIDList(item.ClassID, idx, arrID);
            SetID = 0;
            J0x55:

            // End:0x355 [Loop If]
            if(SetID < arrID.Length)
            {
                bLargeWidth = true;
                ClassID = arrID[SetID];
                // End:0x34B
                if(item.ClassID != ClassID)
                {
                    strTmp = Class'UIDATA_ITEM'.static.GetItemName(ClassID);
                    // End:0x34B
                    if(Len(strTmp) > 0)
                    {
                        StartItem();
                        m_Info.eType = DIT_TEXTURE;
                        m_Info.nOffSetX = 3;
                        m_Info.nOffSetY = 4;
                        m_Info.bLineBreak = true;
                        m_Info.t_bDrawOneLine = true;
                        m_Info.u_nTextureWidth = 18;
                        m_Info.u_nTextureHeight = 18;
                        m_Info.u_nTextureUWidth = 18;
                        m_Info.u_nTextureUHeight = 18;
                        m_Info.u_strTexture = "L2UI_CH3.Tooltip.lifeBG";
                        EndItem();
                        StartItem();
                        m_Info.eType = DIT_TEXTURE;
                        m_Info.nOffSetX = -17;
                        m_Info.nOffSetY = 5;
                        m_Info.t_bDrawOneLine = true;
                        m_Info.u_nTextureWidth = 16;
                        m_Info.u_nTextureHeight = 16;
                        m_Info.u_nTextureUWidth = 32;
                        m_Info.u_nTextureUHeight = 32;
                        m_Info.u_strTexture = Class'UIDATA_ITEM'.static.GetItemTextureName(ClassID);
                        EndItem();
                        StartItem();
                        m_Info.eType = DIT_TEXT;
                        m_Info.nOffSetX = 5;
                        m_Info.nOffSetY = 6;
                        m_Info.t_bDrawOneLine = true;
                        m_Info.t_color.R = 100;
                        m_Info.t_color.G = 100;
                        m_Info.t_color.B = 65;
                        m_Info.t_color.A = byte(255);
                        m_Info.t_strText = strTmp;
                        ParamAdd(m_Info.Condition, "Type", "Equip");
                        ParamAdd(m_Info.Condition, "ServerID", string(item.ServerID));
                        ParamAdd(m_Info.Condition, "EquipID", string(ClassID));
                        ParamAdd(m_Info.Condition, "NormalColor", "100,100,65");
                        ParamAdd(m_Info.Condition, "EnableColor", "255,250,160");
                        EndItem();
                        AddTooltipItemBlank(1);
                    }
                }
                SetID++;
                // [Loop Continue]
                goto J0x55;
            }
            strTmp = Class'UIDATA_ITEM'.static.GetSetItemEffectDescription(item.ClassID, idx);
            // End:0x512
            if(Len(strTmp) > 0)
            {
                bLargeWidth = true;
                StartItem();
                m_Info.eType = DIT_TEXT;
                m_Info.nOffSetX = 5;
                m_Info.nOffSetY = 6;
                m_Info.bLineBreak = true;
                m_Info.t_color.R = 100;
                m_Info.t_color.G = 70;
                m_Info.t_color.B = 0;
                m_Info.t_color.A = byte(255);
                m_Info.t_strText = strTmp;
                ParamAdd(m_Info.Condition, "Type", "SetEffect");
                ParamAdd(m_Info.Condition, "ServerID", string(item.ServerID));
                ParamAdd(m_Info.Condition, "ClassID", string(item.ClassID));
                ParamAdd(m_Info.Condition, "EffectID", string(idx));
                ParamAdd(m_Info.Condition, "NormalColor", "100,70,0");
                ParamAdd(m_Info.Condition, "EnableColor", "255,180,0");
                EndItem();
                AddTooltipItemBlank(2);
                AddCrossLine();
            }
            idx++;
            // [Loop Continue]
            goto J0x1F;
        }
        strTmp = Class'UIDATA_ITEM'.static.GetSetItemEnchantEffectDescription(item.ClassID);
        // End:0x6AC
        if(Len(strTmp) > 0)
        {
            bLargeWidth = true;
            StartItem();
            m_Info.eType = DIT_TEXT;
            m_Info.nOffSetX = 5;
            m_Info.nOffSetY = 2;
            m_Info.bLineBreak = true;
            m_Info.t_color.R = 74;
            m_Info.t_color.G = 92;
            m_Info.t_color.B = 104;
            m_Info.t_color.A = byte(255);
            m_Info.t_strText = strTmp;
            ParamAdd(m_Info.Condition, "Type", "EnchantEffect");
            ParamAdd(m_Info.Condition, "ServerID", string(item.ServerID));
            ParamAdd(m_Info.Condition, "ClassID", string(item.ClassID));
            ParamAdd(m_Info.Condition, "NormalColor", "74,92,104");
            ParamAdd(m_Info.Condition, "EnableColor", "110,140,170");
            EndItem();
        }
    }
    return;
}