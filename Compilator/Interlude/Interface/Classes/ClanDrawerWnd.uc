function int getCurrentGradebyClanType()
{
	local int GradeNum;

	Debug("???? ?????? ??????? ??????:"@string(m_clanType));
	switch(m_clanType)
	{
        // End:0x6D
		case 0:
			GradeNum = 6;
            // End:0xEF
			break;
            // End:0x7D
		case 100:
			GradeNum = 7;
                // End:0xEF
			break;
                // End:0x8D
		case 200:
			GradeNum = 7;
                    // End:0xEF
			break;
                    // End:0xA0
		case 1001:
			GradeNum = 8;
                    // End:0xEF
			break;
                    // End:0xB3
		case 1002:
			GradeNum = 8;
                    // End:0xEF
			break;
                    // End:0xC6
		case 2001:
			GradeNum = 8;
                    // End:0xEF
			break;
                    // End:0xD9
		case 2002:
			GradeNum = 8;
                    // End:0xEF
			break;
                    // End:0xEC
		case -1:
			GradeNum = 9;
                    // End:0xEF
			break;
                    // End:0xFFFF
		default:
			Debug("???? ?????? ??????"@string(GradeNum));
			break;/* Tried to find Switch scope, found Case instead */
			return GradeNum;
	}
}

function CustomTooltip SetTooltip(string Text)
{
	local CustomTooltip ToolTip;
	local DrawItemInfo Info;

	ToolTip.MinimumWidth = 144;
	ToolTip.DrawList.Length = 1;
	Info.eType = DIT_TEXT;
	Info.t_color.R = 178;
	Info.t_color.G = 190;
	Info.t_color.B = 207;
	Info.t_color.A = byte(255);
	Info.t_strText = Text;
	ToolTip.DrawList[0] = Info;
	return ToolTip;
}
