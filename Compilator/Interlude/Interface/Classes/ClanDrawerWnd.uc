function OnEvent(int a_EventID, string a_Param)
{
	Debug("Igotthisevent:"@string(a_EventID));
	switch(a_EventID)
	{
        // End:0x3C
		case 350:
			HandleClanAuthGradeList(a_Param);
            // End:0xF1
			break;
        // End:0x4F
		case 360:
			HandleCrestChange(a_Param);
        // End:0x65
		case 430:
			HandleClanMemberInfo(a_Param);
            // End:0xF1
			break;
        // End:0x7B
		case 370:
			HandleClanAuth(a_Param);
            // End:0xF1
			break;
        // End:0x91
		case 380:
			HandleClanAuthMember(a_Param);
            // End:0xF1
			break;
        // End:0xD5
		case 160:
			Class'UIAPI_WINDOW'.static.HideWindow("ClanDrawerWnd");
			Class'UIAPI_WINDOW'.static.ClearAnchor("ClanDrawerWnd");
            // End:0xF1
			break;
        // End:0xEB
		case 470:
			HandleClearWarList(a_Param);
            // End:0xF1
			break;
        // End:0xFFFF
		default:
            // End:0xF1
			break;
			break;
	}
}

