						else
						{
                            // End:0xCC
							if( gradeID == 2002 )
							{
								stringIndex = 1405;                                
							}
							else
							{
                                // End:0xE6
								if( gradeID == -1 )
								{
									stringIndex = 1419;
								}
							}
						}
					}
				}
			}
		}
	}
    // End:0x104
	if( stringIndex != -1 )
	{
		return GetSystemString(stringIndex);        
	}
	else
	{
		return "";
	}
}

function reset_clan_org()
{
	local int i;

	i = 0;
J0x07:

    // End:0x64 [Loop If]
	if( i < 8 )
	{
		Clan3_OrgIcon[i].HideWindow();
		Clan3_OrgIcon[i].DisableWindow();
		Clan3_OrgIcon[i].SetTooltipCustomType(SetTooltip(""));
		++i;
        // [Loop Continue]
		goto J0x07;
	}
}

