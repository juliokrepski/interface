function OnClickBtnClassChange()
{
    local int Selected, classIndex;

    Selected = m_hCbClassName.GetSelectedNum();
    classIndex = m_hCbClassName.GetReserved(Selected);
    // End:0x56
    if(classIndex >= 0)
    {
        ExecuteCommand("//setclass " @ string(classIndex));
    }
    return;
}

