function HandleShowGMWnd()
{
    // End:0x24
    if(m_hOwnerWnd.IsShowWindow())
    {
        m_hOwnerWnd.HideWindow();        
    }
    else
    {
        m_hOwnerWnd.ShowWindow();
        m_hGMwnd.SetFocus();
    }
    return;
}

function HandleDialogOK()
{
    // End:0x0D
    if(!DialogIsMine())
    {
        return;
    }
    switch(DialogGetID())
    {
        // End:0x22
        case 0:
            Recall();
            // End:0x32
            break;
        // End:0x2F
        case 1:
            SendHome();
            // End:0x32
            break;
        // End:0xFFFF
        default:
            break;
    }
  
}

function HandleTargetUpdate()
{
    local int m_nowTargetID;
    local UserInfo Info;

    m_nowTargetID = Class'UIDATA_TARGET'.static.GetTargetID();
    // End:0x26
    if(m_nowTargetID == m_targetID)
    {
        return;
    }
    // End:0x5D
    if(m_nowTargetID < 1)
    {
        m_targetID = 0;
        // End:0x5B
        if(m_hEditBox.IsEnableWindow())
        {
            m_hEditBox.SetString("");
        }
        return;
    }
    GetTargetInfo(Info);
    // End:0xB1
    if((m_nowTargetID > 0) && Info.bNpc == false)
    {
        // End:0xB1
        if(m_hEditBox.IsEnableWindow())
        {
            m_hEditBox.SetString(Info.Name);
        }
    }
    m_targetID = m_nowTargetID;
    SetClassTypeComboBox();
    return;
}

function HandleDialogCancel()
{
    // End:0x0D
    if(!DialogIsMine())
    {
        return;
    }

}

