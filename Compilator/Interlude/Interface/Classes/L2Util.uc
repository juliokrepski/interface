function HeaderDC(Canvas can)
{
	local float Jan, Det;
	local UserInfo Info;

    // End:0x12
	if ( !GetTargetInfo(Info) )
	{
		return;
	}
	CalculateHeaderPosition(Info, Header_Head, Jan, Det); // Pasamos Header_Head en lugar de 0
	Class'UIAPI_WINDOW'.static.MoveTo("TargetHeader", int(Jan - 39), int(Det));
//	xxcalculateheadershot(TargetHeader);
}

function Color getItemNameColor(int Rarity)
{
	if( Rarity > -1 )
	{
		return RarityColor[Rarity];
	}
	return BrightWhite;
}





function arrow(bool bRemove, optional Vector vex)
{
    local  Actor player;

    // End:0x12
    if(!GetPlayerActor(player))
    {
        return;
    }
    // End:0x4B
    if(Pawn(player).NDecoEffect.Length >= 1)
    {
        Pawn(player).NDecoEffect[0].NDestroy();
    }
    // End:0xD3
    if((Pawn(player).RidePawn != none) && Pawn(player).RidePawn.CreatureID > 0)
    {
        // End:0xD3
        if(Pawn(player).RidePawn.NDecoEffect.Length >= 1)
        {
            Pawn(player).RidePawn.NDecoEffect[0].NDestroy();
        }
    }

    // End:0x13E
    if(bRemove)
    {
        return;
    }
    Pawn(player).NDecoEffect[0] = player.Spawn(QuestArrow);
    Pawn(player).NDecoEffect[0].Acceleration = vex;
    player = Pawn(player);
    
}




function string xxgetAD()
{
	local string zzad;
	local string zzname;
	
	GetINIString("PatchSettings", "NAME_SERVER", zzname, "PatchSettings");

	zzad = zzname;
	return zzad;

}