	kClearItem.ClassID = -1;
	iItemCount = hItemWnd.GetItemNum();
    // End:0x97
	if( iItemCount < iInvenLimit )
	{
		iAddedCount = iInvenLimit - iItemCount;
		iCount = 0;
	J0x67:

        // End:0x94 [Loop If]
		if( iCount < iAddedCount )
		{
			hItemWnd.AddItem(kClearItem);
			iCount++;
            // [Loop Continue]
			goto J0x67;
		}        
	}
	else
	{
        // End:0x142
		if( iItemCount > iInvenLimit )
		{
			iDeletedCount = iItemCount - iInvenLimit;
			iCount = hItemWnd.GetItemNum() - 1;
		J0xD0:

            // End:0x142 [Loop If]
			if( iCount >= 0 )
			{
                // End:0x138
				if( iDeletedCount > 0 )
				{
					hItemWnd.GetItem(iCount, kCurItem);
                    // End:0x12A
					if( !xxIsValidItemID(kCurItem) )
					{
						hItemWnd.DeleteItem(iCount);
						iDeletedCount--;
					}
                    // End:0x138
					if( iDeletedCount <= 0 )
					{
                        // [Explicit Break]
						goto J0x142;
					}
				}
				iCount--;
                // [Loop Continue]
				goto J0xD0;
			}
		}
	}
J0x142:

	return;
}


