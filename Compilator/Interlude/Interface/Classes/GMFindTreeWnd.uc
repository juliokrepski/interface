function ClearList()
{
    m_hFindTreeList.DeleteAllItem();
    m_hFindTreeList.SetTooltipType("");
    return;
}

function int InsertRecordFindTreeList(string fullNameString, string a_Param, int Id)
{
    local string itemParam;
    local int QuestType;
    local LVDataRecord Record;

    Record.LVDataList.Length = 2;

    // Depuración: Imprimir parámetros de entrada
 //   OMG("InsertRecordFindTreeList: fullNameString = " $ fullNameString $ ", a_Param = " $ a_Param $ ", Id = " $ string(Id));

    // End:0x27C
    if((((findMatchString(fullNameString, a_Param)) != -1) || a_Param == "") || a_Param == string(Id))
    {
        Record.LVDataList[0].bUseTextColor = true;
        Record.LVDataList[0].TextColor = Gold;

        // End:0xC1
        if(curListType == LISTTYPE_ITEM)
        {
            itemParam = Class'UIDATA_ITEM'.static.GetItemName(Id);
            Record.szReserved = itemParam;
            Record.nReserved1 = Id;
        }
        else
        {
            // End:0x11B
            if(curListType == LISTTYPE_SKILL)
            {
                Record.LVDataList[1].nReserved1 = makeSkillLevel(Id);
                fullNameString = (fullNameString @ " - Lv ") $ string(Record.LVDataList[1].nReserved1);                
            }
            else
            {
                // End:0x211
                if(curListType == LISTTYPE_QUEST)
                {
                    QuestType = Class'UIDATA_QUEST'.static.GetQuestType(Id, 1);
                    switch(QuestType)
                    {
                        // End:0x173
                        case 0:
                            fullNameString = (fullNameString $ " - ") $ GetSystemString(861);
                            break;
                        // End:0x199
                        case 1:
                            fullNameString = (fullNameString $ " - ") $ GetSystemString(862);
                            break;
                        // End:0x1C0
                        case 2:
                            fullNameString = (fullNameString $ " - ") $ GetSystemString(861);
                            break;
                        // End:0x1E7
                        case 3:
                            fullNameString = (fullNameString $ " - ") $ GetSystemString(862);
                            break;
                        // End:0x20E
                        case 4:
                            fullNameString = (fullNameString $ " - ") $ GetSystemString(861);
                            break;
                        // End:0xFFFF
                        default:
                            break;
                    }
                }
                else
                {
                    // Si hay otros tipos de listas, maneja aquí
                }
            }
        }

        Record.LVDataList[0].szData = fullNameString;
        Record.LVDataList[1].szData = string(Id);
        Record.LVDataList[1].TextColor = Gold;

        // Depuración: Imprimir el registro antes de insertarlo
    //    OMG("Insertando registro: fullNameString = " $ fullNameString $ ", Id = " $ string(Id));

        m_hFindTreeList.InsertRecord(Record);

        // Depuración: Imprimir el número de registros después de la inserción
   //     OMG("Número de registros después de inserción: " $ string(m_hFindTreeList.GetRecordCount()));

        return m_hFindTreeList.GetRecordCount();
    }

    // Depuración: Imprimir cuando no se cumple la condición para insertar
  //  OMG("No se cumplió la condición para insertar el ítem con ID: " $ string(Id) $ " y nombre: " $ fullNameString);

    return m_hFindTreeList.GetRecordCount();
}


function int makeSkillLevel(int Id)
{
    local int i;

    i = 1;
    J0x07:

    // End:0x46 [Loop If]
    if(i < 50)
    {
        // End:0x3C
        if(Class'UIDATA_SKILL'.static.GetName(Id, i) == "")
        {
            return i - 1;
        }
        i++;
        // [Loop Continue]
        goto J0x07;
    }
    return 1;

}

function openDialogNumpad(int Num)
{
    DialogSetID(10000);
    DialogSetEditType("number");
    DialogSetParamInt(Num);
    DialogSetDefaultOK();
    DialogShow(EDialogType(6), "Count to Spawn");
    return;
}

function bool GetSelectedListCtrlItem(out LVDataRecord Record)
{
    local int Index;

    Index = m_hFindTreeList.GetSelectedIndex();
    // End:0x3C
    if(Index >= 0)
    {
        Record = m_hFindTreeList.GetRecord(Index);
        return true;
    }
    return false;

}

function Summon(int cnt)
{
    local LVDataRecord Record;

    Record.LVDataList.Length = 2;
    // End:0x1AD
    if(GetSelectedListCtrlItem(Record))
    {
        // End:0x1AD
        if(Record.LVDataList[1].szData != "")
        {
            switch(curListType)
            {
                // End:0x75
                case LISTTYPE_ITEM:
                    ProcessChatMessage(("//create_item" @ Record.LVDataList[1].szData) @ string(cnt), 0);
                    // End:0x1AD
                    break;
                // End:0xA9
                case LISTTYPE_NPC:
                    ProcessChatMessage(("//spawn" @ Record.LVDataList[1].szData) @ string(cnt), 0);
                    // End:0x1AD
                    break;
                // End:0xF2
                case LISTTYPE_SKILL:
                    ProcessChatMessage((("//add_skill" @ Record.LVDataList[1].szData) @ " ") @ string(Record.LVDataList[1].nReserved1), 0);
                    // End:0x1AD
                    break;
                // End:0x120
                case LISTTYPE_CLASS:
                    ProcessChatMessage("//setclass" @ Record.LVDataList[1].szData, 0);
                    // End:0x1AD
                    break;
                // End:0x158
                case LISTTYPE_QUEST:
                    ProcessChatMessage((("//setquest" @ Record.LVDataList[1].szData) @ " ") @ string(0), 0);
                    // End:0x1AD
                    break;
                // End:0x181
                case LISTTYPE_SYSTEMSTRING:
                    ProcessChatMessage("///ss" @ Record.LVDataList[1].szData, 0);
                    // End:0x1AD
                    break;
                // End:0x1AA
                case LISTTYPE_SYSTEMMESSAGE:
                    ProcessChatMessage("///sm" @ Record.LVDataList[1].szData, 0);
                    // End:0x1AD
                    break;
                // End:0xFFFF
                default:
                    break;
            }
        }
        else
        {
        }
        return;
    }
}

