function HandleDialogOK()
{
    local int inputNum, Id;

    // End:0x0D
    if(!DialogIsMine())
    {
        return;
    }
    Id = DialogGetID();
    // End:0x41
    if(Id == 10000)
    {
        inputNum = int(DialogGetString());
        Summon(inputNum);
    }
    return;
}

function OnClickButton(string strID)
{
    switch(strID)
    {
        // End:0x8B
        case "btnSummon":
            switch(curListType)
            {
                // End:0x2B
                case LISTTYPE_ITEM:
                    openDialogNumpad(1);
                    // End:0x88
                    break;
                // End:0x3A
                case LISTTYPE_NPC:
                    openDialogNumpad(1);
                    // End:0x88
                    break;
                // End:0x49
                case LISTTYPE_SKILL:
                    Summon(1);
                    // End:0x88
                    break;
                // End:0x58
                case LISTTYPE_QUEST:
                    Summon(1);
                    // End:0x88
                    break;
                // End:0x67
                case LISTTYPE_CLASS:
                    Summon(1);
                    // End:0x88
                    break;
                // End:0x76
                case LISTTYPE_SYSTEMSTRING:
                    Summon(1);
                    // End:0x88
                    break;
                // End:0x85
                case LISTTYPE_SYSTEMMESSAGE:
                    Summon(1);
                    // End:0x88
                    break;
                // End:0xFFFF
                default:
                    break;
            }
            // End:0xA3
            break;
        // End:0xA0
        case "btnFind":
            handleFind();
            // End:0xA3
            break;
        // End:0xFFFF
        default:
            break;
    }

}

function handleFind()
{
    local string EditBoxString;

    EditBoxString = m_hEditBox.GetString();
    ShowList(EditBoxString, curListType);
    return;
}

function ShowList(string a_Param, EListType listType)
{
    Me.HideWindow();
    curListType = listType;
    m_hEditBox.SetString(a_Param);
    m_hComboBox.SetSelectedNum(curListType);
    m_hBtnSummon.DisableWindow();
    switch(curListType)
    {
        // End:0x6D
        case LISTTYPE_ITEM:
		//OMG(a_Param);
            FindAllItem(a_Param);
            // End:0xE2
            break;
        // End:0x80
        case LISTTYPE_NPC:
	//	OMG(a_Param);
            FindAllNPC(a_Param);
            // End:0xE2
            break;
        // End:0x93
        case LISTTYPE_SKILL:
            FindAllSkill(a_Param);
            // End:0xE2
            break;
        // End:0xA6
        case LISTTYPE_QUEST:
            FindAllQuest(a_Param);
            // End:0xE2
            break;
        // End:0xB9
        case LISTTYPE_CLASS:
            FindAllCLASS(a_Param);
            // End:0xE2
            break;
        // End:0xCC
        case LISTTYPE_SYSTEMSTRING:
            FindAllSystemString(a_Param);
            // End:0xE2
            break;
        // End:0xDF
        case LISTTYPE_SYSTEMMESSAGE:
            FindAllSystemMessage(a_Param);
            // End:0xE2
            break;
        // End:0xFFFF
        default:
            break;
    }
    Me.ShowWindow();
    Me.SetFocus();
 
}

function FindAllItem(string searchStr)
{
    local int cID;
    local string fullNameString;
    local ItemInfo Info, cls;

    ClearList();
    cID = Class'UIDATA_ITEM'.static.GetFirstID();

    // Depuración: Imprimir el primer ID obtenido
  //  OMG("Primer ID obtenido: " $ string(cID));

    J0x1B:

    // End:0xE7 [Loop If]
    if(cID < Class'UIDATA_ITEM'.static.GetDataCount())
    {
        Info = cls;
    
        // Verificar si se obtiene información válida del item
        if(Class'UIDATA_ITEM'.static.GetItemInfo(cID, Info))
        {
            fullNameString = Class'UIDATA_ITEM'.static.GetItemName(cID);

            // Verificar si Info.Name tiene un valor válido
            if (Len(fullNameString) > 0)
            {
                // End:0x9F
                if(Len(Info.AdditionalName) > 0)
                {
                    fullNameString = ((fullNameString $ " (") $ Info.AdditionalName) $ ")";
                }

                // Depuración: Imprimir el nombre completo del ítem antes de insertar
            //    OMG("Nombre del ítem: " $ fullNameString);

                // Insertar en la lista y verificar si se alcanzó el límite
                if((InsertRecordFindTreeList(fullNameString, searchStr, cID)) == 1000)
                {
               //     OMG("Límite de 1000 ítems alcanzado.");
                    return;
                }

                // Depuración: Imprimir el ID del ítem válido
             //   OMG("Procesando item con ID: " $ string(cID));
            }
            else
            {
                // Ignorar ítem sin nombre válido
                // OMG("Ítem con ID " $ string(cID) $ " no tiene nombre válido.");
            }
        }
        else
        {
            // Ignorar ítem que no se pudo obtener información
            // OMG("No se pudo obtener información del ítem con ID " $ string(cID));
        }
        
        cID++;
        // [Loop Continue]
        goto J0x1B;
    }

    // Depuración: Imprimir al finalizar el bucle
  //  OMG("Bucle finalizado. Último ID procesado: " $ string(cID));

    return;
}




function FindAllNPC(string a_Param)
{
    local int Id;
    local string fullNameString;

    ClearList();
    Id = Class'UIDATA_NPC'.static.GetFirstID();
    J0x1B:

    // End:0xB0 [Loop If]
    if(-1 != Id)
    {
        // End:0x98
        if(Class'UIDATA_NPC'.static.IsValidData(Id))
        {
            fullNameString = Class'UIDATA_NPC'.static.GetNPCName(Id);
            // End:0x98
            if((InsertRecordFindTreeList(fullNameString, a_Param, Id)) == 1000)
            {
                SysDebug("Limite de 1000 Npcs.");
                return;
            }
        }
        Id = Class'UIDATA_NPC'.static.GetNextID();
        // [Loop Continue]
        goto J0x1B;
    }
    return;
}

function FindAllSkill(string a_Param)
{
    local int cID;
    local string fullNameString;

    ClearList();
    cID = Class'UIDATA_SKILL'.static.GetFirstID();
    J0x1B:

    // End:0xA4 [Loop If]
    if(cID < Class'UIDATA_ITEM'.static.GetDataCount())
    {
        fullNameString = Class'UIDATA_SKILL'.static.GetName(cID, 1);
        // End:0x9A
        if(fullNameString != "")
        {
            // End:0x9A
            if((InsertRecordFindTreeList(fullNameString, a_Param, cID)) == 1000)
            {
                SysDebug("Limite de 1000 Skills.");
                return;
            }
        }
        cID++;
        // [Loop Continue]
        goto J0x1B;
    }
    return;
}

function FindAllQuest(string a_Param)
{
    local int Id;
    local string fullNameString;

    ClearList();
    Id = Class'UIDATA_QUEST'.static.GetFirstID();
    J0x1B:

    // End:0xA4 [Loop If]
    if(Id < 2000)
    {
        // End:0x9A
        if(Class'UIDATA_QUEST'.static.IsValidData(Id))
        {
            fullNameString = Class'UIDATA_QUEST'.static.GetQuestName(Id);
