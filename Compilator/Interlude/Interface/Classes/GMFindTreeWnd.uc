    ClearList();
    classIndex = 0;
    J0x0D:

    // End:0x61 [Loop If]
    if(classIndex < 200)
    {
        fullNameString = getclassx(classIndex);
        // End:0x57
        if(fullNameString != "")
        {
            // End:0x57
            if((InsertRecordFindTreeList(fullNameString, a_Param, classIndex)) == 1000)
            {
                return;
