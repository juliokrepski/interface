function InitInterfaceOptions()
{
	local bool bOption;
 
 
	bOption = GetOptionBool("ScreenDamage", "nDamage");
	if( bOption == True )
	{
		Cb_Damage.SetCheck(True);        
	}
	else
	{
		Cb_Damage.SetCheck(False);
	}
