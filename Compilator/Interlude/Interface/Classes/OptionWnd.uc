        bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.KeyboardBox");
        SetKeyCrypt(bChecked);
    }
    nSelectedNum = GetComboBoxHandle("OptionWnd.cbBuffSize").GetSelectedNum();
    SetOptionInt("Game", "BuffSize", nSelectedNum);
    return;
}

function OnClickButton(string strID)
{
    Debug(strID);
    switch(strID)
    {
        // End:0x25
        case "VideoCancelBtn":
        // End:0x38
        case "AudioCancelBtn":
        // End:0x130
        case "GameCancelBtn":
            SetOptionInt("FirstRun", "FirstRun", 2);
            // End:0x113
            if(GetOptionBool("Audio", "AudioMuteOn") == false)
            {
                OnModifyCurrentTickSliderCtrl("EffectVolumeSliderCtrl", m_iPrevSoundTick);
                OnModifyCurrentTickSliderCtrl("MusicVolumeSliderCtrl", m_iPrevMusicTick);
                OnModifyCurrentTickSliderCtrl("SystemVolumeSliderCtrl", m_iPrevSystemTick);
                OnModifyCurrentTickSliderCtrl("TutorialVolumeSliderCtrl", m_iPrevTutorialTick);
            }
            Class'UIAPI_WINDOW'.static.HideWindow("OptionWnd");
            // End:0x250
            break;
        // End:0x13F
        case "VideoOKBtn":
        // End:0x14E
        case "AudioOKBtn":
        // End:0x1A7
        case "GameOKBtn":
            ApplyVideoOption();
            ApplyAudioOption();
            ApplyGameOption();
            SetOptionInt("FirstRun", "FirstRun", 2);
            Class'UIAPI_WINDOW'.static.HideWindow("OptionWnd");
            // End:0x250
            break;
        // End:0x1B9
        case "VideoApplyBtn":
        // End:0x1CB
        case "AudioApplyBtn":
        // End:0x1F1
        case "GameApplyBtn":
            ApplyVideoOption();
            ApplyAudioOption();
            ApplyGameOption();
            // End:0x250
            break;
        // End:0x20C
        case "WindowInitBtn":
            SetDefaultPosition();
            // End:0x250
            break;
        // End:0x222
        case "btnVideo":
            SetTabVideo();
            // End:0x250
            break;
        // End:0x238
        case "btnAudio":
            SetTabAudio();
            // End:0x250
            break;
        // End:0x24D
        case "btnGame":
            SetTabGame();
            // End:0x250
            break;
		case "btnDamage":
			SetTabDamage();
			 // End:0x1D0
			break;
		case "btnOn":
			EnableAll();
			break;
		case "btnOff":
			DisableAll();
			break;		
        // End:0xFFFF
        default:
            break;
    }

}





function SetTabVideo()
{
	showTabVideo = True;
	showTabAudio = False;
	showTabGame = False;
	ShowTabDamage = False;
	ShowHideTab(showTabVideo, showTabAudio, showTabGame, ShowTabDamage);
	return;
}
 
function SetTabAudio()
{
	showTabVideo = False;
	showTabAudio = True;
	showTabGame = False;
	ShowTabDamage = False;
	ShowHideTab(showTabVideo, showTabAudio, showTabGame, ShowTabDamage);
	return;
}
 
function SetTabGame()
{
	showTabVideo = False;
	showTabAudio = False;
	showTabGame = True;
	ShowTabDamage = False;
	ShowHideTab(showTabVideo, showTabAudio, showTabGame, ShowTabDamage);
	return;
}
 
function SetTabDamage()
{
	showTabVideo = False;
	showTabAudio = False;
	showTabGame = False;
	ShowTabDamage = True;
	ShowHideTab(showTabVideo, showTabAudio, showTabGame, ShowTabDamage);
	return;
}
function ShowHideTab(bool bvideo, bool baudio, bool bgame, bool bDamage)
{
    // End:0x7E
    if(bvideo)
    {
        ShowWindow("VideoTab");
        btnVideo.SetTexture("L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON_over");        
    }
    else
    {
        HideWindow("VideoTab");
        btnVideo.SetTexture("L2UI_CH3.OptionWnd.btnOFF", "L2UI_CH3.OptionWnd.btnOFF_down", "L2UI_CH3.OptionWnd.btnOFF_over");
    }
    // End:0x176
    if(baudio)
    {
        ShowWindow("AudioTab");
        btnAudio.SetTexture("L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON_over");        
    }
    else
    {
        HideWindow("AudioTab");
        btnAudio.SetTexture("L2UI_CH3.OptionWnd.btnOFF", "L2UI_CH3.OptionWnd.btnOFF_down", "L2UI_CH3.OptionWnd.btnOFF_over");
    }
    // End:0x26D
    if(bgame)
    {
        ShowWindow("GameTab");
        btnGame.SetTexture("L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON_over");        
    }
    else
    {
        HideWindow("GameTab");
        btnGame.SetTexture("L2UI_CH3.OptionWnd.btnOFF", "L2UI_CH3.OptionWnd.btnOFF_down", "L2UI_CH3.OptionWnd.btnOFF_over");
    }
	
    // End:0x26D
    if(bDamage)
    {
        ShowWindow("DamageTab");
        btnDamage.SetTexture("L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON", "L2UI_CH3.OptionWnd.btnON_over");        
    }
    else
    {
        HideWindow("DamageTab");
        btnDamage.SetTexture("L2UI_CH3.OptionWnd.btnOFF", "L2UI_CH3.OptionWnd.btnOFF_down", "L2UI_CH3.OptionWnd.btnOFF_over");
    }	
	

}

function ShowHideDamage(string wnd, bool Show)
{
	 // End:0x17
	if( Show )
	{
		ShowWindow(wnd);        
	}
	else
	{
		HideWindow(wnd);
	}
	return;
}
 
