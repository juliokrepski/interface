        // End:0x36D
        if((0 <= fWavVoiceVolume) && fWavVoiceVolume < 0.2)
        {
            iSystemVolume = 0;            
        }
        else
        {
            // End:0x397
            if((0.2 <= fWavVoiceVolume) && fWavVoiceVolume < 0.4)
            {
                iSystemVolume = 1;                
            }
            else
            {
                // End:0x3C2
                if((0.4 <= fWavVoiceVolume) && fWavVoiceVolume < 0.6)
                {
                    iSystemVolume = 2;                    
                }
                else
                {
                    // End:0x3ED
                    if((0.6 <= fWavVoiceVolume) && fWavVoiceVolume < 0.8)
                    {
                        iSystemVolume = 3;                        
                    }
                    else
                    {
                        // End:0x418
                        if((0.8 <= fWavVoiceVolume) && fWavVoiceVolume < 1)
                        {
                            iSystemVolume = 4;                            
                        }
                        else
                        {
                            // End:0x42F
                            if(1 <= fWavVoiceVolume)
                            {
                                iSystemVolume = 5;
                            }
                        }
                    }
                }
            }
        }
        Class'UIAPI_SLIDERCTRL'.static.SetCurrentTick("OptionWnd.SystemVolumeSliderCtrl", iSystemVolume);
        fOggVoiceVolume = GetOptionFloat("Audio", "OggVoiceVolume");
        gOggVoiceVolume = fOggVoiceVolume;
        // End:0x4BD
        if((0 <= fOggVoiceVolume) && fOggVoiceVolume < 0.2)
        {
            iTutorialVolume = 0;            
        }
        else
        {
            // End:0x4E7
            if((0.2 <= fOggVoiceVolume) && fOggVoiceVolume < 0.4)
            {
                iTutorialVolume = 1;                
            }
            else
            {
                // End:0x512
                if((0.4 <= fOggVoiceVolume) && fOggVoiceVolume < 0.6)
                {
                    iTutorialVolume = 2;                    
                }
                else
                {
                    // End:0x53D
                    if((0.6 <= fOggVoiceVolume) && fOggVoiceVolume < 0.8)
                    {
                        iTutorialVolume = 3;                        
                    }
                    else
                    {
                        // End:0x568
                        if((0.8 <= fOggVoiceVolume) && fOggVoiceVolume < 1)
                        {
                            iTutorialVolume = 4;                            
                        }
                        else
                        {
                            // End:0x57F
                            if(1 <= fOggVoiceVolume)
                            {
                                iTutorialVolume = 5;
                            }
                        }
                    }
                }
            }
        }
        Class'UIAPI_SLIDERCTRL'.static.SetCurrentTick("OptionWnd.TutorialVolumeSliderCtrl", iTutorialVolume);
        m_iPrevSoundTick = iSoundVolume;
        m_iPrevMusicTick = iMusicVolume;
        m_iPrevSystemTick = iSystemVolume;
        m_iPrevTutorialTick = iTutorialVolume;        
