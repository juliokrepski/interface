	bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.rDamage");
	ShowHideDamage("OptionWnd.tex_rDamage", bChecked);
	bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.acquiredXP");
	ShowHideDamage("OptionWnd.tex_acquiredXP", bChecked);
	bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.acquiredSP");
	ShowHideDamage("OptionWnd.tex_acquiredSP", bChecked);
	bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.nDamage");
	ShowHideDamage("OptionWnd.tex_nDamage", bChecked);
	bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.critical");
	ShowHideDamage("OptionWnd.tex_critical", bChecked);
	bChecked = Class'UIAPI_CHECKBOX'.static.IsChecked("OptionWnd.overhit");
