function CustomTooltip infotooltip(string param)
{
    local CustomTooltip ToolTip;
    local DrawItemInfo detocaj;

    ToolTip.DrawList.Length = 1;
    detocaj.eType = DIT_TEXT;
    detocaj.t_strText = param;
    ToolTip.DrawList[0] = detocaj;
    return ToolTip;

}

