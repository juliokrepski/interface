function OnEvent(int Event_ID, string param)
{
    switch(Event_ID)
    {
        // End:0x1D
        case 2530:
            HandleShopID(param);
            // End:0x7C
            break;
        // End:0x33
        case 2540:
            HandleItemList(param);
            // End:0x7C
            break;
        // End:0x49
        case 2550:
            HandleNeededItemList(param);
            // End:0x7C
            break;
        // End:0x65
        case 2560:
            HandleItemListEnd(param);
            CheckMS();
            // End:0x7C
            break;
        // End:0x76
        case 1710:
            HandleDialogOK();
            // End:0x7C
            break;
        // End:0xFFFF
        default:
            // End:0x7C
            break;

    }

}

function CheckMS()
{
    local int i, tmpInt;
    local string tmp;

    isExecMultisell(false);
    i = 0;
    J0x0E:

    // End:0x93 [Loop If]
    if(i < m_MultiSellInfoList.Length)
    {
        tmp = string(m_MultiSellInfoList[i].OutputItemInfoList[0].Reserved);
        // End:0x63
        if(Len(tmp) > 5)
        {
            tmp = Left(tmp, Len(tmp) - 5);
        }
        tmpInt = int(tmp);
        // End:0x89
        if(tmpInt != (i + 1))
        {
            isExecMultisell(true);
        }
        i++;
        // [Loop Continue]
        goto J0x0E;
    }
    MultisellTab.InitTabCtrl();
    MultisellTabTotalWnd_ListCtrl.SetScrollPosition(0);
    MultisellTabEnableWnd_ListCtrl.SetScrollPosition(0);
    return;
}

function isExecMultisell(bool Exec)
{
    // End:0x62
    if(!Exec)
    {
        MultisellTab.SetDisable(1, false);
        Search_EditBox.EnableWindow();
        GetWindowHandle("MultisellWnd.searchDisable").HideWindow();
        isExec = false;        
    }
    else
    {
        MultisellTab.SetDisable(1, true);
        Search_EditBox.DisableWindow();
        GetWindowHandle("MultisellWnd.searchDisable").ShowWindow();
        isExec = true;
    }
    return;
}

function OnShow()
{
    MultisellTab.InitTabCtrl();
    toggleListWithIconWindow(true);
    ItemCount_EditBox.SetString("1");
    Search_EditBox.SetString("");
    GlobalItemCount = 1;
    GlobalAvailable = 0;
    lastFalseItem = -1;
    return;
}

function OnHide()
{
    // End:0x0F
    if(DialogIsMine())
    {
        DialogHide();
    }
    iniListWithItemWindow();
    return;
}

function OnClickButton(string Name)
{
    switch(Name)
    {
        // End:0x35
        case "Close_Button":
            Clear();
            HideWindow("MultiSellWnd");
            // End:0x145
            break;
        // End:0x52
        case "ExChange_Button":
            HandleOKButton();
            // End:0x145
            break;
        // End:0x69
        case "IconTabIcon_Button":
        // End:0x89
        case "ListTabIcon_Button":
            toggleListWithIconWindow();
            // End:0x145
            break;
        // End:0xA4
        case "Search_Button":
            OnSearch_ButtonClick();
            // End:0x145
            break;
        // End:0xC0
        case "Refresh_Button":
            OnRefresh_ButtonClick();
            // End:0x145
            break;
        // End:0xDA
        case "Clear_Button":
            OnClear_ButtonClick();
            // End:0x145
            break;
        // End:0xFB
        case "MultiSell_Up_Button":
            OnMultiSell_Up_ButtonClick();
            // End:0x145
            break;
        // End:0x11E
        case "MultiSell_Down_Button":
            OnMultiSell_Down_ButtonClick();
            // End:0x145
            break;
        // End:0x142
        case "MultiSell_Input_Button":
            OnPriceEditBtnHandler();
            // End:0x145
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x197
    if(Left(Name, 4) == "root")
    {
        OnClickItem("MultisellTabTotalWnd_ItemWindow", int(Mid(Name, 5)) - 1);
        updateUIControl();        
    }
    else
    {
        // End:0x1E9
        if(Left(Name, 6) == "enable")
        {
            OnClickItem("MultisellTabEnableWnd_ItemWindow", int(Mid(Name, 11)) - 1);
            updateUIControl();
        }
    }
    return;
}

function toggleListWithIconWindow(optional bool bInit)
{
    // End:0x27
    if(bInit)
    {
        // INVERTA ESTAS DUAS LINHAS:
        IconTabIcon_Button.ShowWindow(); 
        ListTabIcon_Button.HideWindow();
    }
    
    // End:0xF0
    if(ListTabIcon_Button.IsShowWindow())
    {
        IconTabIcon_Button.ShowWindow();
        ListTabIcon_Button.HideWindow();
        MultisellTabTotalWnd_ItemWindow.HideWindow();
        MultisellTabEnableWnd_ItemWindow.HideWindow();
        MultisellTabTotalWnd_ListCtrl.ShowWindow();
        MultisellTabEnableWnd_ListCtrl.ShowWindow();
        listGroupBg_Texture_MultisellTabIistWnd.ShowWindow();
        listGroupBg_Texture_MultisellTabIistWnd2.ShowWindow();
        listSlotBg1_Texture_MultisellTabIconWnd.HideWindow();
        listSlotBg2_Texture_MultisellTabIconWnd.HideWindow();
        listSlotBg1_Texture_MultisellTabIconWnd2.HideWindow();
        listSlotBg2_Texture_MultisellTabIconWnd2.HideWindow();        
    }
    else
    {
        IconTabIcon_Button.HideWindow();
        ListTabIcon_Button.ShowWindow();
        MultisellTabTotalWnd_ListCtrl.HideWindow();
        MultisellTabEnableWnd_ListCtrl.HideWindow();
        MultisellTabTotalWnd_ItemWindow.ShowWindow();
        MultisellTabEnableWnd_ItemWindow.ShowWindow();
        listGroupBg_Texture_MultisellTabIistWnd.HideWindow();
        listGroupBg_Texture_MultisellTabIistWnd2.HideWindow();
        listSlotBg1_Texture_MultisellTabIconWnd.ShowWindow();
        listSlotBg2_Texture_MultisellTabIconWnd.ShowWindow();
        listSlotBg1_Texture_MultisellTabIconWnd2.ShowWindow();
        listSlotBg2_Texture_MultisellTabIconWnd2.ShowWindow();
