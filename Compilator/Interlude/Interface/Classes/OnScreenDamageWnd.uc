}

function string formatByType(int Type, string Value)
{
    switch(Type)
    {
        // End:0x0E
        case 0:
        // End:0x1B
        case 1:
            return Value;
        // End:0x22
        case 2:
        // End:0x29
        case 4:
        // End:0x30
        case 3:
        // End:0x37
        case 5:
        // End:0x49
        case 6:
            return "+" $ Value;
        // End:0x50
        case 8:
        // End:0x57
        case 7:
        // End:0x5E
        case 9:
        // End:0x65
        case 11:
        // End:0x6F
        case 10:
            return "";
        // End:0xFFFF
        default:

            break;
    }
}

