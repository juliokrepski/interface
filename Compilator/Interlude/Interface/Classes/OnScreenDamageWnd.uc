function SetTextToTex(int Value, int Type)
{
    local int i, W, H, U, V, tmpContainer;

    local string tmpValue, tmpDigit;
    local TextureHandle tmpDigitTex[10];

    lastContainer++;
	
	
	    if((Value < -1) || Value > 999999999)
    {
        Value = 999999999;
    }
	
	
    tmpValue = formatByType(Type, string(Value));
    // End:0x32
    if(lastContainer >= 20)
    {
        lastContainer = 0;
    }
    tmpContainer = lastContainer;
    wContainer[tmpContainer].MoveTo((getInitXPos(Type)) - ((Len(tmpValue) * 24) / 2), getInitYPos(Type));
    i = 0;
    J0x80:

    // End:0xF8 [Loop If]
    if(i < 10)
    {
        tmpDigitTex[i] = GetTextureHandle((("OnScreenDamageWnd.Damage" $ string(tmpContainer)) $ "Wnd.Digit") $ string(i));
        tmpDigitTex[i].SetWindowSize(0, 0);
        ++i;
        // [Loop Continue]
        goto J0x80;
    }
    // End:0x15C
    if(tmpValue == "")
    {
        getSpecInfo(Type, W, H, U, V);
        tmpDigitTex[0].SetUV(U, V);
        tmpDigitTex[0].SetWindowSize(W, H);        
    }
    else
    {
        i = 0;
        J0x163:

        // End:0x35C [Loop If]
        if(i < Len(tmpValue))
        {
            tmpDigit = Right(Left(tmpValue, i + 1), 1);
            // End:0x1D5
            if(tmpDigit == "+")
            {
                tmpDigitTex[i].SetUV(200, Type * 24);
                tmpDigitTex[i].SetWindowSize(47, 24);                
            }
            else
            {
                // End:0x219
                if((Type == 0) && isCritical)
                {
                    tmpDigitTex[i].SetUV(int(tmpDigit) * 20, 2 * 24);                    
                }
                else
                {
                    tmpDigitTex[i].SetUV(int(tmpDigit) * 20, Type * 24);
                }
                tmpDigitTex[i].SetWindowSize(20, 24);
            }
            // End:0x352
            if(i >= 1)
            {
                // End:0x2EC
                if((Left(tmpValue, 1) == "+") && i == 1)
                {
                    tmpDigitTex[i].SetAnchor((("OnScreenDamageWnd.Damage" $ string(tmpContainer)) $ "Wnd.Digit") $ string(i - 1), "TopLeft", "TopLeft", 45, 0);
                    // [Explicit Continue]
                    goto J0x352;
                }
                tmpDigitTex[i].SetAnchor((("OnScreenDamageWnd.Damage" $ string(tmpContainer)) $ "Wnd.Digit") $ string(i - 1), "TopLeft", "TopLeft", 20, 0);
            }
            J0x352:

            i++;
            // [Loop Continue]
            goto J0x163;
        }
    }
    wContainer[tmpContainer].Move(0, getMovePos(Type), 2.2);
    wContainer[tmpContainer].ShowWindow();
    Me.SetTimer(tmpContainer + 10000, 2000);
    isCritical = false;

}

