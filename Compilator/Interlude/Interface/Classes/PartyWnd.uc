function UpdateCPBar(int idx, int Value, int MaxValue)
{
    m_BarCP[idx].SetValue(MaxValue, Value);
    return;
}

function UpdateHPBar(int idx, int Value, int MaxValue)
{
    m_BarHP[idx].SetValue(MaxValue, Value);
    // End:0x57
    if(Value < 1)
    {
        m_BGLDisable[idx].ShowWindow();
        m_BGRDisable[idx].ShowWindow();        
    }
    else
    {
        m_BGLDisable[idx].HideWindow();
        m_BGRDisable[idx].HideWindow();
    }
    return;
}

function UpdateMPBar(int idx, int Value, int MaxValue)
{
    m_BarMP[idx].SetValue(MaxValue, Value);
    return;
}

function OnLButtonDown(WindowHandle a_WindowHandle, int X, int Y)
{
    local Rect rectWnd;
    local UserInfo UserInfo;
    local int idx;

    rectWnd = m_wndTop.GetRect();
    // End:0xBE
    if((X > (rectWnd.nX + 13)) && X < ((rectWnd.nX + rectWnd.nWidth) - 10))
    {
        // End:0xBE
        if(GetPlayerInfo(UserInfo))
        {
            idx = (Y - rectWnd.nY) / 61;
            // End:0xA3
            if(IsPKMode())
            {
                RequestAttack(m_arrID[idx], UserInfo.Loc);                
            }
            else
            {
                RequestAction(m_arrID[idx], UserInfo.Loc);
            }
        }
    }
    return;
}

function OnRButtonUp(int X, int Y)
{
    local Rect rectWnd;
    local UserInfo UserInfo;
    local int idx;

    rectWnd = m_wndTop.GetRect();
    // End:0xC2
    if((X > (rectWnd.nX + 13)) && X < ((rectWnd.nX + rectWnd.nWidth) - 10))
    {
        // End:0xC2
        if(GetPlayerInfo(UserInfo))
        {
            idx = (Y - rectWnd.nY) / 61;
            m_animAssist[idx].SetLoopCount(1);
            m_animAssist[idx].Play();
            RequestAssist(m_arrID[idx], UserInfo.Loc);
        }
    }
    return;
}

function HandleCheckTarget()
{
    local int idx;

    idx = -1;
    m_targetID = Class'UIDATA_TARGET'.static.GetTargetID();
    // End:0x3C
    if(m_targetID > 0)
    {
        idx = FindPartyID(m_targetID);
    }
    // End:0x109
    if(m_LastChangeColor != -1)
    {
        m_BGLeft[m_LastChangeColor].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGLeft");
        m_BGCenter[m_LastChangeColor].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGCenter");
        m_BGRight[m_LastChangeColor].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGRight");
        m_targetID = -1;
        m_LastChangeColor = -1;
    }
    // End:0x1EB
    if(idx >= 0)
    {
        m_LastChangeColor = idx;
        m_BGLeft[idx].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGLeft_OverClassic");
        m_BGCenter[idx].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGCenter_OverClassic");
        m_BGRight[idx].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGRight_OverClassic");
    }
    return;
}

function SetBuffButtonTooltip()
{
    switch(m_CurBf)
    {
        // End:0x14
        case 0:
            TooltipBuff0();
            // End:0x4E
            break;
        // End:0x21
        case 1:
            TooltipBuff1();
            // End:0x4E
            break;
        // End:0x2F
        case 2:
            TooltipBuff2();
            // End:0x4E
            break;
        // End:0x3D
        case 3:
            TooltipBuff3();
            // End:0x4E
            break;
        // End:0x4B
        case 4:
            TooltipBuff4();
            // End:0x4E
            break;
        // End:0xFFFF
        default:
            break;
    }
    return;
}

function TooltipBuff0()
{
    local CustomTooltip TooltipInfo;

    TooltipInfo.DrawList.Length = 4;
    TooltipInfo.DrawList[0].eType = DIT_TEXT;
    TooltipInfo.DrawList[0].nOffSetX = 1;
    TooltipInfo.DrawList[0].t_bDrawOneLine = true;
    TooltipInfo.DrawList[0].t_color.R = 128;
    TooltipInfo.DrawList[0].t_color.G = 128;
    TooltipInfo.DrawList[0].t_color.B = 128;
    TooltipInfo.DrawList[0].t_color.A = byte(255);
    TooltipInfo.DrawList[0].t_strText = GetSystemString(1496);
