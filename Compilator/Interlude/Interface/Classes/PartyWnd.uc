    m_BGLDisable[idx].HideWindow();
    m_BGRDisable[idx].HideWindow();
    m_BGLeft[idx].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGLeft");
    m_BGCenter[idx].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGCenter");
    m_BGRight[idx].SetTexture("L2UI_CH3.PartyWnd.PartyWndBGRight");
    return;
}

