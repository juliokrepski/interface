function OnEvent(int Event_ID, string param)
{
    // End:0x18
    if(Event_ID == 980)
    {
        HandleCheckTarget();        
    }
    else
    {
        // End:0x35
        if(Event_ID == 1140)
        {
            HandlePartyAddParty(param);            
        }
        else
        {
            // End:0x52
            if(Event_ID == 1150)
            {
                HandlePartyUpdateParty(param);                
            }
            else
            {
                // End:0x6F
                if(Event_ID == 1160)
                {
                    HandlePartyDeleteParty(param);                    
                }
                else
                {
                    // End:0x87
                    if(Event_ID == 1170)
                    {
                        HandlePartyDeleteAllParty();                        
                    }
                    else
                    {
                        // End:0xA4
                        if(Event_ID == 1180)
                        {
                            HandlePartySpelledList(param);                            
                        }
                        else
                        {
                            // End:0xC1
                            if(Event_ID == 1000)
                            {
                                HandleShowBuffIcon(param);                                
                            }
                            else
                            {
                                // End:0xD3
                                if(Event_ID == 40)
                                {
                                    HandleRestart();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    return;
}

function HandleRestart()
{
    Clear();
    return;
}

