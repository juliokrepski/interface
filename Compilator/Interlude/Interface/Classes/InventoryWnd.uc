{
    InvenClear();
    invenItem_1Clear();
    invenItem_2Clear();
    invenItem_3Clear();
    invenItem_4Clear();
    QuestInvenClear();
    EquipItemClear();
    m_EarItemList.Length = 0;
    m_FingerItemLIst.Length = 0;
    InvenLimitUpdate();
    return;
}

