    Class'UIAPI_TEXTBOX'.static.SetText("ExpBarWnd.textAdenaCount", adenaString);
    Class'UIAPI_TEXTBOX'.static.SetTextColor("ExpBarWnd.textAdenaCount", AdenaColor);
    return;
}

function UseItem(ItemWindowHandle a_hItemWindow, int Index)
{
    local ItemInfo Info;

    // End:0xB1
    if(a_hItemWindow.GetItem(Index, Info))
    {
        // End:0x5B
        if(Info.bRecipe)
        {
            DialogSetReservedInt(Info.ServerID);
            DialogSetID(1111);
            DialogShow(DIALOG_Warning, GetSystemMessage(798));            
        }
        else
        {
            // End:0xA1
            if(Info.PopMsgNum > 0)
            {
                DialogSetID(2222);
                DialogSetReservedInt(Info.ServerID);
                DialogShow(DIALOG_Warning, GetSystemMessage(Info.PopMsgNum));                
            }
            else
            {
                RequestUseItem(Info.ServerID);
            }
        }
    }
    return;
}

function SaveItemOrder()
{
    local ItemInfo Info;
    local int i;

    m_itemOrder.Length = m_invenItem.GetItemNum();
    i = 0;
    J0x1D:

    // End:0x66 [Loop If]
    if(i < m_itemOrder.Length)
    {
        m_invenItem.GetItem(i, Info);
        m_itemOrder[i] = Info.ClassID;
        ++i;
        // [Loop Continue]
        goto J0x1D;
    }
    SaveInventoryOrder(m_itemOrder);
    return;
}

function LoadItemOrder()
{
    LoadInventoryOrder(m_itemOrder);
    return;
}

function OrderItem()
{
    local int newItemIndex, ItemNum, itemIndex, orderIndex;
    local ItemInfo Info;
    local bool matched;

    newItemIndex = 0;
    ItemNum = m_invenItem.GetItemNum();
    itemIndex = 0;
    J0x23:

    // End:0xCE [Loop If]
    if(itemIndex < ItemNum)
    {
        m_invenItem.GetItem(itemIndex, Info);
        matched = false;
        orderIndex = 0;
        J0x5A:

        // End:0x99 [Loop If]
        if(orderIndex < m_itemOrder.Length)
        {
            // End:0x8F
            if(Info.ClassID == m_itemOrder[orderIndex])
            {
                matched = true;
                // [Explicit Break]
                goto J0x99;
            }
            ++orderIndex;
            // [Loop Continue]
            goto J0x5A;
        }
        J0x99:

        // End:0xC4
        if(!matched)
        {
            m_invenItem.SwapItems(itemIndex, newItemIndex);
            ++newItemIndex;
        }
        ++itemIndex;
        // [Loop Continue]
        goto J0x23;
    }
    orderIndex = 0;
    J0xD5:

    // End:0x177 [Loop If]
    if(orderIndex < m_itemOrder.Length)
    {
        itemIndex = 0;
        J0xEC:

        // End:0x16D [Loop If]
        if(itemIndex < ItemNum)
        {
            m_invenItem.GetItem(itemIndex, Info);
            // End:0x163
            if((Info.ClassID == m_itemOrder[orderIndex]) && Info.ServerID > 0)
            {
                m_invenItem.SwapItems(itemIndex, newItemIndex);
                ++newItemIndex;
                // [Explicit Break]
                goto J0x16D;
            }
            ++itemIndex;
            // [Loop Continue]
            goto J0xEC;
        }
        J0x16D:

        ++orderIndex;
        // [Loop Continue]
        goto J0xD5;
    }
    return;
}

