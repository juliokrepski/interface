function int EquipItemGetItemNum()
{
    local int i, ItemNum;

    i = 0;
    J0x07:

    // End:0x57 [Loop If]
    if(i < 15)
    {
        // End:0x4D
        if(m_equipItem[i].IsEnableWindow())
        {
            ItemNum = ItemNum + m_equipItem[i].GetItemNum();
        }
        ++i;
        // [Loop Continue]
        goto J0x07;
    }
    return ItemNum;

}

function EquipItemClear()
{
    local int i;

    i = 0;
    J0x07:

    // End:0x32 [Loop If]
    if(i < 15)
    {
        m_equipItem[i].Clear();
        ++i;
        // [Loop Continue]
        goto J0x07;
    }
    return;
}

function bool EquipItemFind(int a_ServerID)
{
    local int i, Index;

    i = 0;
    J0x07:

    // End:0x4E [Loop If]
    if(i < 15)
    {
        Index = m_equipItem[i].FindItemWithServerID(a_ServerID);
        // End:0x44
        if(-1 != Index)
        {
            return true;
        }
        ++i;
        // [Loop Continue]
        goto J0x07;
    }
    return false;

}

function EquipItemDelete(int a_ServerID)
{
    local int i, Index;
    local ItemInfo TheItemInfo;

    i = 0;
    J0x07:

    // End:0xD7 [Loop If]
    if(i < 15)
    {
        Index = m_equipItem[i].FindItemWithServerID(a_ServerID);
        // End:0xCD
        if(-1 != Index)
        {
            m_equipItem[i].Clear();
            // End:0xCD
            if(i == 7)
            {
                // End:0xCD
                if(m_equipItem[5].GetItem(0, TheItemInfo))
                {
                    // End:0xCD
                    if(TheItemInfo.SlotBitType == 16384)
                    {
                        m_equipItem[7].Clear();
                        m_equipItem[7].AddItem(TheItemInfo);
                        m_equipItem[7].DisableWindow();
                    }
                }
            }
        }
        ++i;
        // [Loop Continue]
        goto J0x07;
    }
    return;
}

function EarItemUpdate()
{
    local int i, LEarIndex, REarIndex;

    LEarIndex = -1;
    REarIndex = -1;
    i = 0;
    J0x1D:

    // End:0x8D [Loop If]
    if(i < m_EarItemList.Length)
    {
        switch(IsLOrREar(m_EarItemList[i].ServerID))
        {
            // End:0x5B
            case -1:
                LEarIndex = i;
                // End:0x83
                break;
            // End:0x6E
            case 0:
                m_EarItemList.Remove(i, 1);
                // End:0x83
                break;
            // End:0x80
            case 1:
                REarIndex = i;
                // End:0x83
                break;
            // End:0xFFFF
            default:
                break;
        }
        ++i;
        // [Loop Continue]
        goto J0x1D;
    }
    // End:0xCB
    if(-1 != LEarIndex)
    {
        m_equipItem[9].Clear();
        m_equipItem[9].AddItem(m_EarItemList[LEarIndex]);
    }
    // End:0x109
    if(-1 != REarIndex)
    {
        m_equipItem[8].Clear();
        m_equipItem[8].AddItem(m_EarItemList[REarIndex]);
    }
    return;
}

function FingerItemUpdate()
{
    local int i, LFingerIndex, RFingerIndex;

    LFingerIndex = -1;
    RFingerIndex = -1;
    i = 0;
    J0x1D:

    // End:0x8D [Loop If]
    if(i < m_FingerItemLIst.Length)
    {
        switch(IsLOrRFinger(m_FingerItemLIst[i].ServerID))
        {
            // End:0x5B
            case -1:
                LFingerIndex = i;
                // End:0x83
                break;
            // End:0x6E
            case 0:
                m_FingerItemLIst.Remove(i, 1);
                // End:0x83
                break;
            // End:0x80
            case 1:
                RFingerIndex = i;
                // End:0x83
                break;
            // End:0xFFFF
            default:
                break;
        }
        ++i;
        // [Loop Continue]
        goto J0x1D;
    }
    // End:0xCB
    if(-1 != LFingerIndex)
    {
        m_equipItem[14].Clear();
        m_equipItem[14].AddItem(m_FingerItemLIst[LFingerIndex]);
    }
    // End:0x109
    if(-1 != RFingerIndex)
    {
        m_equipItem[13].Clear();
        m_equipItem[13].AddItem(m_FingerItemLIst[RFingerIndex]);
    }
    return;
}

function EquipItemUpdate(ItemInfo a_Info)
{
    local ItemWindowHandle hItemWnd;
    local ItemInfo TheItemInfo;
    local bool ClearLHand;
    local ItemInfo RHand, LHand, Legs, Gloves, Feet, Hair2;

    local int i;

    switch(a_Info.SlotBitType)
    {
        // End:0x20
        case 1:
            hItemWnd = m_equipItem[0];
            // End:0x650
            break;
        // End:0x25
        case 2:
        // End:0x2A
        case 4:
        // End:0xB7
        case 6:
            i = 0;
            J0x36:

            // End:0x72 [Loop If]
            if(i < m_EarItemList.Length)
            {
                // End:0x68
                if(m_EarItemList[i].ServerID == a_Info.ServerID)
                {
                    // [Explicit Break]
                    goto J0x72;
                }
                ++i;
                // [Loop Continue]
                goto J0x36;
            }
            J0x72:

            // End:0xA7
            if(i == m_EarItemList.Length)
            {
                m_EarItemList.Length = m_EarItemList.Length + 1;
                m_EarItemList[m_EarItemList.Length - 1] = a_Info;
            }
            hItemWnd = none;
            EarItemUpdate();
            // End:0x650
            break;
        // End:0xCD
        case 8:
            hItemWnd = m_equipItem[4];
            // End:0x650
            break;
        // End:0xD2
        case 16:
        // End:0xD7
        case 32:
        // End:0x164
        case 48:
            i = 0;
            J0xE3:

            // End:0x11F [Loop If]
            if(i < m_FingerItemLIst.Length)
            {
                // End:0x115
                if(m_FingerItemLIst[i].ServerID == a_Info.ServerID)
                {
                    // [Explicit Break]
                    goto J0x11F;
                }
                ++i;
                // [Loop Continue]
                goto J0xE3;
            }
            J0x11F:

            // End:0x154
            if(i == m_FingerItemLIst.Length)
            {
                m_FingerItemLIst.Length = m_FingerItemLIst.Length + 1;
                m_FingerItemLIst[m_FingerItemLIst.Length - 1] = a_Info;
            }
            hItemWnd = none;
            FingerItemUpdate();
            // End:0x650
            break;
        // End:0x188
        case 64:
            hItemWnd = m_equipItem[1];
            hItemWnd.EnableWindow();
            // End:0x650
            break;
        // End:0x19E
        case 128:
            hItemWnd = m_equipItem[5];
            // End:0x650
            break;
        // End:0x1C6
        case 256:
            hItemWnd = m_equipItem[7];
            hItemWnd.EnableWindow();
            // End:0x650
            break;
        // End:0x1EE
        case 512:
            hItemWnd = m_equipItem[10];
            hItemWnd.EnableWindow();
            // End:0x650
            break;
        // End:0x207
        case 1024:
            hItemWnd = m_equipItem[6];
            // End:0x650
            break;
        // End:0x22F
        case 2048:
            hItemWnd = m_equipItem[11];
            hItemWnd.EnableWindow();
            // End:0x650
            break;
        // End:0x257
        case 4096:
            hItemWnd = m_equipItem[12];
            hItemWnd.EnableWindow();
            // End:0x650
            break;
        // End:0x26F
        case 8192:
            hItemWnd = m_equipItem[0];
            // End:0x650
            break;
        // End:0x3C2
        case 16384:
            hItemWnd = m_equipItem[5];
            ClearLHand = true;
            // End:0x2CC
            if(IsBowOrFishingRod(a_Info))
            {
                // End:0x2CC
                if(m_equipItem[7].GetItem(0, TheItemInfo))
                {
                    // End:0x2CC
                    if(IsArrow(TheItemInfo))
                    {
                        ClearLHand = false;
                    }
                }
            }
            // End:0x3BF
            if(ClearLHand)
            {
                // End:0x384
                if(Len(a_Info.IconNameEx1) != 0)
                {
                    RHand = a_Info;
                    LHand = a_Info;
                    RHand.IconIndex = 1;
                    LHand.IconIndex = 2;
                    m_equipItem[5].Clear();
                    m_equipItem[5].AddItem(RHand);
                    m_equipItem[7].Clear();
                    m_equipItem[7].AddItem(LHand);
                    m_equipItem[7].DisableWindow();
                    hItemWnd = none;                    
                }
                else
                {
                    m_equipItem[7].Clear();
                    m_equipItem[7].AddItem(a_Info);
                    m_equipItem[7].DisableWindow();
                }
            }
            // End:0x650
            break;
        // End:0x436
        case 32768:
            hItemWnd = m_equipItem[6];
            Legs = a_Info;
            Legs.IconName = a_Info.IconNameEx2;
            m_equipItem[11].Clear();
            m_equipItem[11].AddItem(Legs);
            m_equipItem[11].DisableWindow();
            // End:0x650
            break;
        // End:0x44F
        case 65536:
            hItemWnd = m_equipItem[2];
            // End:0x650
            break;
        // End:0x5D1
        case 131072:
            hItemWnd = m_equipItem[6];
            Hair2 = a_Info;
            Gloves = a_Info;
            Legs = a_Info;
            Feet = a_Info;
            Hair2.IconName = a_Info.IconNameEx1;
            Gloves.IconName = a_Info.IconNameEx2;
            Legs.IconName = a_Info.IconNameEx3;
            Feet.IconName = a_Info.IconNameEx4;
            m_equipItem[1].Clear();
            m_equipItem[1].AddItem(Hair2);
            m_equipItem[1].DisableWindow();
            m_equipItem[10].Clear();
            m_equipItem[10].AddItem(Gloves);
            m_equipItem[10].DisableWindow();
            m_equipItem[11].Clear();
            m_equipItem[11].AddItem(Legs);
            m_equipItem[11].DisableWindow();
            m_equipItem[12].Clear();
            m_equipItem[12].AddItem(Feet);
            m_equipItem[12].DisableWindow();
            // End:0x650
            break;
        // End:0x5F9
        case 262144:
            hItemWnd = m_equipItem[3];
            hItemWnd.EnableWindow();
            // End:0x650
            break;
        // End:0x64D
        case 524288:
            hItemWnd = m_equipItem[2];
            m_equipItem[3].Clear();
            m_equipItem[3].AddItem(a_Info);
            m_equipItem[3].DisableWindow();
            // End:0x650
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x67E
    if(none != hItemWnd)
    {
        hItemWnd.Clear();
        hItemWnd.AddItem(a_Info);
    }
    return;
}

function HandleOpenWindow()
{
    LoadItemOrder();
    ShowWindow(m_WindowName);
    Class'UIAPI_WINDOW'.static.SetFocus(m_WindowName);
    return;
}

function HandleHideWindow()
{
    HideWindow(m_WindowName);
    return;
}

function HandleAddItem(string param)
{
    local ItemInfo Info;

    ParamToItemInfo(param, Info);
    // End:0x2C
    if(IsEquipItem(Info))
    {
        EquipItemUpdate(Info);        
    }
    else
    {
        // End:0x48
        if(IsQuestItem(Info))
        {
            QuestInvenAddItem(Info);            
        }
        else
        {
            NormalInvenAddItem(Info);
        }
    }
    return;
}

function NormalInvenAddItem(ItemInfo NewItem)
{
    local int idx, CurLimit, FindIdx;
    local ItemInfo CurItem;
    local ItemWindowHandle detailItemWindow;

    FindIdx = -1;
    CurLimit = m_invenItem.GetItemNum();
    isAdena(NewItem);
    // End:0x90
    if(FindIdx < 0)
    {
        idx = 0;
        J0x3D:

        // End:0x90 [Loop If]
        if(idx < CurLimit)
        {
            // End:0x86
            if(m_invenItem.GetItem(idx, CurItem))
            {
                // End:0x86
                if(!xxIsValidItemID(CurItem))
                {
                    FindIdx = idx;
                    // [Explicit Break]
                    goto J0x90;
                }
            }
            idx++;
            // [Loop Continue]
            goto J0x3D;
        }
    }
    J0x90:

    // End:0xBB
    if(FindIdx > -1)
    {
        m_invenItem.SetItem(FindIdx, NewItem);        
    }
    else
    {
        m_invenItem.AddItem(NewItem);
    }
    m_NormalInvenCount++;
    detailItemWindow = getItemWindowHandleByItemType(NewItem);
    FindIdx = -1;
    idx = 0;
    J0xF9:

    // End:0x14C [Loop If]
    if(idx < CurLimit)
    {
        // End:0x142
        if(detailItemWindow.GetItem(idx, CurItem))
        {
            // End:0x142
            if(!xxIsValidItemID(CurItem))
            {
                FindIdx = idx;
                // [Explicit Break]
                goto J0x14C;
            }
        }
        idx++;
        // [Loop Continue]
        goto J0xF9;
    }
    J0x14C:

    // End:0x177
    if(FindIdx > -1)
    {
        detailItemWindow.SetItem(FindIdx, NewItem);        
    }
    else
    {
        detailItemWindow.AddItem(NewItem);
    }
    return;
}

function QuestInvenAddItem(ItemInfo NewItem)
{
    local int idx, CurLimit, FindIdx;
    local ItemInfo CurItem;

    FindIdx = -1;
    // End:0x85
    if(FindIdx < 0)
    {
        CurLimit = m_questItem.GetItemNum();
        idx = 0;
        J0x32:

        // End:0x85 [Loop If]
        if(idx < CurLimit)
        {
            // End:0x7B
            if(m_questItem.GetItem(idx, CurItem))
            {
                // End:0x7B
                if(!xxIsValidItemID(CurItem))
                {
                    FindIdx = idx;
                    // [Explicit Break]
                    goto J0x85;
                }
            }
            idx++;
            // [Loop Continue]
            goto J0x32;
        }
    }
    J0x85:

    // End:0xB0
    if(FindIdx > -1)
    {
        m_questItem.SetItem(FindIdx, NewItem);        
    }
    else
    {
        m_questItem.AddItem(NewItem);
    }
    m_QuestInvenCount++;
    return;
}

function ItemWindowHandle getItemWindowHandleBystrTarget(string strTarget)
{
    switch(strTarget)
    {
        // End:0x22
        case "InventoryItem":
            return m_invenItem;
            // End:0x69
            break;
        // End:0x33
        case InventoryItem_1:
            return m_invenItem_1;
            // End:0x69
            break;
        // End:0x44
        case InventoryItem_2:
            return m_invenItem_2;
            // End:0x69
            break;
        // End:0x55
        case InventoryItem_3:
            return m_invenItem_3;
            // End:0x69
            break;
        // End:0x66
        case InventoryItem_4:
            return m_invenItem_4;
            // End:0x69
            break;
        // End:0xFFFF
        default:
            break;
    }

}

function ItemWindowHandle getItemWindowHandleByItemType(ItemInfo item)
{
    local EItemType EItemType;

    // End:0x16
    if(!xxIsValidItemID(item))
    {
        return m_invenItem_4;
    }
    EItemType = EItemType(item.ItemType);
    switch(EItemType)
    {
        // End:0x3A
        case ITEM_ASSET:
            return m_invenItem_4;
        // End:0x3F
        case ITEM_WEAPON:
        // End:0x44
        case ITEM_ARMOR:
        // End:0x4F
        case ITEM_ACCESSARY:
            return m_invenItem_1;
        // End:0x110
        case ITEM_ETCITEM:
            switch(byte(item.ItemSubType))
            {
                // End:0x67
                case 1:
                // End:0x6C
                case 2:
                // End:0x71
                case 3:
                // End:0x76
                case 19:
                // End:0x7B
                case 20:
                // End:0x80
                case 21:
                // End:0x85
                case 22:
                // End:0x8A
                case 24:
                // End:0x8F
                case 23:
                // End:0x9A
                case 16:
                    return m_invenItem_2;
                // End:0x9F
                case 5:
                // End:0xAA
                case 6:
                    return m_invenItem_3;
                // End:0xAF
                case 0:
                // End:0xB4
                case 4:
                // End:0xB9
                case 7:
                // End:0xBE
                case 8:
                // End:0xC3
                case 9:
                // End:0xC8
                case 10:
                // End:0xCD
                case 11:
                // End:0xD2
                case 12:
                // End:0xD7
                case 13:
                // End:0xDC
                case 14:
                // End:0xE1
                case 15:
                // End:0xE6
                case 17:
                // End:0x10A
                case 18:
                    // End:0x104
                    if(xxisConsumable(item.ClassID))
                    {
                        return m_invenItem_2;
                    }
                    return m_invenItem_4;
                // End:0xFFFF
                default:
                    // End:0x119
                    break;
             
            }
        // End:0xFFFF
        default:
            return m_invenItem_4;
            break;
    }

}

function isAdena(ItemInfo Info)
{
    local INT64 adenas;

    // End:0x13
    if(Info.ClassID != 57)
    {
        return;
    }
    adenas = Int2Int64(GetAdena());
    QuitReportWndScript.UpdateAdena(adenas);
    return;
}

function HandleUpdateItem(string param)
{
    local string Type;
    local ItemInfo Info;
    local int Index;
    local ItemWindowHandle detailItemWindowHandle;

    ParseString(param, "type", Type);
    ParamToItemInfo(param, Info);
    // End:0x50
    if((GetPotionType(Info.ClassID)) >= 0)
    {
        s_autoPotions.InsertPotion(Info);
    }
    // End:0x86
    if(Info.ClassID == s_expBar.itemCountID)
    {
        s_expBar.HandleItemIDcount(Info.ItemNum);
    }
    // End:0xEF
    if(Type == "add")
    {
        // End:0xB1
        if(IsEquipItem(Info))
        {
            EquipItemUpdate(Info);            
        }
        else
        {
            // End:0xCD
            if(IsQuestItem(Info))
            {
                QuestInvenAddItem(Info);                
            }
            else
            {
                QuitReportWndScript.externalAddItem(Info);
                NormalInvenAddItem(Info);
            }
        }        
    }
    else
    {
        // End:0x284
        if(Type == "update")
        {
            // End:0x149
            if(IsEquipItem(Info))
            {
                // End:0x130
                if(EquipItemFind(Info.ServerID))
                {
                    EquipItemUpdate(Info);                    
                }
                else
                {
                    InvenDelete(Info);
                    EquipItemUpdate(Info);
                }                
            }
            else
            {
                // End:0x1BF
                if(IsQuestItem(Info))
                {
                    Index = m_questItem.FindItemWithServerID(Info.ServerID);
                    // End:0x1A1
                    if(Index != -1)
                    {
                        m_questItem.SetItem(Index, Info);                        
                    }
                    else
                    {
                        EquipItemDelete(Info.ServerID);
                        QuestInvenAddItem(Info);
                    }                    
                }
                else
                {
                    Index = m_invenItem.FindItemWithServerID(Info.ServerID);
                    // End:0x266
                    if(Index != -1)
                    {
                        isAdena(Info);
                        QuitReportWndScript.externalAddItem(Info);
                        m_invenItem.SetItem(Index, Info);
                        detailItemWindowHandle = getItemWindowHandleByItemType(Info);
                        detailItemWindowHandle.SetItem(detailItemWindowHandle.FindItemWithServerID(Info.ServerID), Info);                        
                    }
                    else
                    {
                        EquipItemDelete(Info.ServerID);
                        NormalInvenAddItem(Info);
                    }
                }
            }            
        }
        else
        {
            // End:0x306
            if(Type == "delete")
            {
                // End:0x2B7
                if(IsEquipItem(Info))
                {
                    EquipItemDelete(Info.ServerID);                    
                }
                else
                {
                    // End:0x2FB
                    if(IsQuestItem(Info))
                    {
                        Index = m_questItem.FindItemWithServerID(Info.ServerID);
                        m_questItem.DeleteItem(Index);                        
                    }
                    else
                    {
                        InvenDelete(Info);
                    }
                }
            }
        }
    }
    SetAdenaText();
    SetItemCount();
    return;
}

function InvenDelete(ItemInfo item)
{
    local int FindIdx, DetailFindIdx;
    local ItemWindowHandle detailItemWindow;

    detailItemWindow = getItemWindowHandleByItemType(item);
    FindIdx = m_invenItem.FindItemWithServerID(item.ServerID);
    DetailFindIdx = detailItemWindow.FindItemWithServerID(item.ServerID);
    // End:0x8D
    if(FindIdx != -1)
    {
        m_invenItem.DeleteItem(FindIdx);
        detailItemWindow.DeleteItem(DetailFindIdx);
        m_NormalInvenCount--;
    }
    return;
}

function QuestInvenDelete(ItemInfo item)
{
    local int FindIdx;

    FindIdx = m_questItem.FindItemWithServerID(item.ServerID);
    // End:0x49
    if(FindIdx != -1)
    {
        m_questItem.DeleteItem(FindIdx);
        m_QuestInvenCount--;
    }
    return;
}

function HandleItemListEnd()
{
    SetAdenaText();
    SetItemCount();
    OrderItem();
    SortAll();
    return;
}

