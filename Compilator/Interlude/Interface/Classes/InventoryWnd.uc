function OnEvent(int Event_ID, string param)
{
    switch(Event_ID)
    {
        // End:0x15
        case 40:
            HandleRestart();
            // End:0xF8
            break;
        // End:0x26
        case 650:
            ClearHenna();
            // End:0xF8
            break;
        // End:0x37
        case 2570:
            HandleClear();
            // End:0xF8
            break;
        // End:0x48
        case 2580:
            HandleOpenWindow();
            // End:0xF8
            break;
        // End:0x59
        case 2590:
            HandleHideWindow();
            // End:0xF8
            break;
        // End:0x6F
        case 2600:
            HandleAddItem(param);
            // End:0xF8
            break;
        // End:0x85
        case 2610:
            HandleUpdateItem(param);
            // End:0xF8
            break;
        // End:0x96
        case 2620:
            HandleItemListEnd();
            // End:0xF8
            break;
        // End:0xAC
        case 2630:
            HandleAddHennaInfo(param);
            // End:0xF8
            break;
        // End:0xC2
        case 260:
            HandleUpdateHennaInfo(param);
            // End:0xF8
            break;
        // End:0xD3
        case 2631:
            HandleToggleWindow();
            // End:0xF8
            break;
        // End:0xE4
        case 1710:
            HandleDialogOK();
            // End:0xF8
            break;
        // End:0xF2
        case 180:
            HandleUpdateUserInfo();
            // End:0xF8
            break;
        // End:0xFFFF
        default:
            // End:0xF8
            break;
            break;
    }

}

function OnShow()
{
    // End:0x36
    if(Class'UIDATA_PLAYER'.static.HasCrystallizeAbility())
    {
        ShowWindow(m_WindowName $ ".CrystallizeButton");        
    }
    else
    {
        HideWindow(m_WindowName $ ".CrystallizeButton");
    }
    SetAdenaText();
    SetItemCount();
    UpdateHennaInfo();
    return;
}

function OnHide()
{
    SaveItemOrder();
