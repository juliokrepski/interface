class WhispAlertWnd extends UICommonAPI;

var int zzi;
var ChatWindowHandle zzWhispChat;
var ExpBarWnd zzExpScript;

function OnLoad()
{
	zzWhispChat = ChatWindowHandle(GetHandle("WhispAlertWnd.WhispChat"));
	zzExpScript = ExpBarWnd(GetScript("ExpBarWnd"));
	zzWhispChat.SetScrollBarPosition(5, 10, 5);
	xxClear();
	return;
}

function OnShow()
{
	zzi = 0;
	return;
}

function xxClear()
{
	zzi = 0;
	zzWhispChat.Clear();
	return;
}

function WhispMessage(string zzparam)
{
	local int zznTmp;
	local string zzText;
	local Color zzColor;

	ParseString(zzparam, "Msg", zzText);
	ParseInt(zzparam, "ColorR", zznTmp);
	zzColor.R = byte(zznTmp);
	ParseInt(zzparam, "ColorG", zznTmp);
	zzColor.G = byte(zznTmp);
	ParseInt(zzparam, "ColorB", zznTmp);
	zzColor.B = byte(zznTmp);
	zzColor.A = byte(255);
    // End:0xE9
	if( Mid(zzText, 0, 2) != "->" )
	{
		zzi++;
		zzWhispChat.AddString(zzText, zzColor);
		zzExpScript.AddWhispInfo(zzi);
	}
	return;
}