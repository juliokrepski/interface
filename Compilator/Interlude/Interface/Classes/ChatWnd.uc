function OnLoad()
{
    m_filterInfo.Length = 5 + 1;
    RegisterEvent(540);
    RegisterEvent(550);
    RegisterEvent(560);
    RegisterEvent(570);
    RegisterEvent(571);
    RegisterEvent(572);
    m_sectionName.Length = 5;
