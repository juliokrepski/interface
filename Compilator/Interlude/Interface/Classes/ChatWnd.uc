    ChatTabCtrl = TabHandle(GetHandle("ChatWnd.ChatTabCtrl"));
    ChatEditBox = EditBoxHandle(GetHandle("ChatWnd.ChatEditBox"));
  
    return;
}

function InitScrollBarPosition()
{
    NormalChat.SetScrollBarPosition(5, 10, -25);
