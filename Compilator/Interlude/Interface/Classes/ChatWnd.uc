}

function HandleTextLinkLButtonClick(string param)
{
    ChatEditBox.AddString(param);
    return;
}

function OnCompleteEditBox(string strID)
{
    local string strInput;
    local EChatType Type;

    // End:0xE1
    if(strID == "ChatEditBox")
    {
        strInput = ChatEditBox.GetString();
        // End:0x3B
        if(Len(strInput) < 1)
        {
            return;
        }
        ProcessChatMessage(strInput, m_chatType);
        ChatEditBox.SetString("");
        // End:0xB1
        if(GetOptionBool("Game", "OldChatting") == true)
        {
            Type = GetChatTypeByTabIndex(m_chatType);
            // End:0xB1
            if(m_chatType != 0)
            {
                ChatEditBox.AddString(GetChatPrefix(Type));
            }
        }
        // End:0xE1
        if(GetOptionBool("Game", "EnterChatting") == true)
        {
            ChatEditBox.ReleaseFocus();
        }
    }
    return;
}

function Clear()
{
	ChatEditBox.Clear();
	NormalChat.Clear();
	PartyChat.Clear();
	ClanChat.Clear();
	TradeChat.Clear();
	AllyChat.Clear();
	SystemMsg.Clear();
    return;
}

function OnShow()
{
    // End:0x34
    if(GetOptionBool("Game", "SystemMsgWnd"))
    {
        ShowWindow("SystemMsgWnd");        
    }
    else
    {
        HideWindow("SystemMsgWnd");
    }
    return;
}

function OnClickButton(string strID)
{
    local PartyMatchWnd script;

    script = PartyMatchWnd(GetScript("PartyMatchWnd"));
    switch(strID)
    {
        // End:0x38
        case "ChatTabCtrl0":
        // End:0x49
        case "ChatTabCtrl1":
        // End:0x5A
        case "ChatTabCtrl2":
        // End:0x6B
        case "ChatTabCtrl3":
        // End:0x8A
        case "ChatTabCtrl4":
            HandleTabClick(strID);
            // End:0x1A0
            break;
        // End:0x105
        case "ChatFilterBtn":
            // End:0xDE
            if(Class'UIAPI_WINDOW'.static.IsShowWindow("ChatFilterWnd"))
            {
                Class'UIAPI_WINDOW'.static.HideWindow("ChatFilterWnd");                
            }
            else
            {
                SetChatFilterButton();
                Class'UIAPI_WINDOW'.static.ShowWindow("ChatFilterWnd");
            }
            // End:0x1A0
            break;
        // End:0x11F
        case "MessengerBtn":
            ToggleMsnWindow();
            // End:0x1A0
            break;
        // End:0x19A
        case "PartyMatchingBtn":
            // End:0x188
            if(Class'UIAPI_WINDOW'.static.IsShowWindow("PartyMatchWnd") == true)
            {
                Class'UIAPI_WINDOW'.static.HideWindow("PartyMatchWnd");
                script.OnSendPacketWhenHiding();                
            }
            else
            {
                Class'PartyMatchAPI'.static.RequestOpenPartyMatch();
            }
            // End:0x1A0
            break;
        // End:0xFFFF
        default:
            // End:0x1A0
            break;
        
    }
 
}

function OnTabSplit(string sTabButton)
{
    local ChatWindowHandle Handle;

    switch(sTabButton)
    {
        // End:0x31
        case "ChatTabCtrl0":
            Handle = NormalChat;
            HandleTabClick(sTabButton);
            // End:0xDF
            break;
        // End:0x5B
        case "ChatTabCtrl1":
            Handle = TradeChat;
            HandleTabClick(sTabButton);
            // End:0xDF
            break;
        // End:0x85
        case "ChatTabCtrl2":
            Handle = PartyChat;
            HandleTabClick(sTabButton);
            // End:0xDF
            break;
        // End:0xAF
        case "ChatTabCtrl3":
            Handle = ClanChat;
            HandleTabClick(sTabButton);
            // End:0xDF
            break;
        // End:0xD9
        case "ChatTabCtrl4":
            Handle = AllyChat;
            HandleTabClick(sTabButton);
            // End:0xDF
            break;
        // End:0xFFFF
        default:
            // End:0xDF
            break;
         
    }
    // End:0x125
    if(Handle != none)
    {
        Handle.SetWindowSizeRel(-1, -1, 0, 0);
        Handle.SetSettledWnd(true);
        Handle.EnableTexture(true);
    }
    return;
}

function OnTabMerge(string sTabButton)
{
    local ChatWindowHandle Handle;
    local int Width, Height;
    local Rect rectWnd;

    switch(sTabButton)
    {
        // End:0x26
        case "ChatTabCtrl0":
            Handle = NormalChat;
            // End:0xA8
            break;
        // End:0x45
        case "ChatTabCtrl1":
            Handle = TradeChat;
            // End:0xA8
            break;
        // End:0x64
        case "ChatTabCtrl2":
            Handle = PartyChat;
            // End:0xA8
            break;
        // End:0x83
        case "ChatTabCtrl3":
            Handle = ClanChat;
            // End:0xA8
            break;
        // End:0xA2
        case "ChatTabCtrl4":
            Handle = AllyChat;
            // End:0xA8
            break;
        // End:0xFFFF
        default:
            // End:0xA8
            break;
            break;
    }
    // End:0x160
    if(Handle != none)
    {
        rectWnd = NormalChat.GetRect();
        NormalChat.GetWindowSize(Width, Height);
        Handle.SetSettledWnd(false);
        Handle.MoveTo(rectWnd.nX, rectWnd.nY);
        Handle.SetWindowSize(Width, Height - 46);
        Handle.SetWindowSizeRel(1, 1, 0, -46);
        Handle.EnableTexture(false);
    }
    return;
}

function HandleTabClick(string strID)
{
    local string strInput, strPrefix;
    local int StrLen;

    m_chatType = ChatTabCtrl.GetTopIndex();
    SetChatFilterButton();
    // End:0x10D
    if(GetOptionBool("Game", "OldChatting") == true)
    {
        strInput = ChatEditBox.GetString();
        StrLen = Len(strInput);
        strPrefix = Left(strInput, 1);
        // End:0xC5
        if((((IsSameChatPrefix(EChatType(8), strPrefix)) || IsSameChatPrefix(EChatType(3), strPrefix)) || IsSameChatPrefix(EChatType(4), strPrefix)) || IsSameChatPrefix(EChatType(9), strPrefix))
        {
            strInput = Right(strInput, StrLen - 1);
        }
        // End:0xF9
        if(m_chatType != 0)
        {
            strPrefix = GetChatPrefix(GetChatTypeByTabIndex(m_chatType));
            strInput = strPrefix $ strInput;
        }
        ChatEditBox.SetString(strInput);
    }
    return;
}

function OnEnterState(name a_PrevStateName)
{
    // End:0x15
    if(a_PrevStateName == 'LoadingState')
    {
        Clear();
    }
    return;
}

function OnEvent(int Event_ID, string param)
{
    switch(Event_ID)
    {
        // End:0x1D
        case 540:
            HandleChatmessage(param);
            // End:0x87
            break;
        // End:0x2E
        case 550:
            HandleChatWndStatusChange();
            // End:0x87
            break;
        // End:0x3F
        case 570:
            HandleSetFocus();
            // End:0x87
            break;
        // End:0x55
        case 560:
            HandleSetString(param);
            // End:0x87
            break;
        // End:0x6B
        case 571:
            HandleMsnStatus(param);
            // End:0x87
            break;
        // End:0x81
        case 572:
            HandleChatWndMacroCommand(param);
            // End:0x87
            break;
        // End:0xFFFF
        default:
            // End:0x87
            break;
            break;
    }
    return;
}

function HandleChatWndMacroCommand(string param)
{
    local string Command;

    // End:0x20
    if(!ParseString(param, "Command", Command))
    {
        return;
    }
    ProcessChatMessage(Command, m_chatType);
    return;
}

function HandleFilterChatMessage(string param)
{
    local string strParam, Text;
    local int Type, ColorR, ColorG, ColorB, ItemID;

    ParseInt(param, "Type", Type);
    ParseString(param, "Msg", Text);
    ParseInt(param, "ColorR", ColorR);
    ParseInt(param, "ColorG", ColorG);
    ParseInt(param, "ColorB", ColorB);
    ParseInt(param, "ItemID", ItemID);
    ParamAdd(strParam, "Type", string(Type));
    ParamAdd(strParam, "ColorR", string(ColorR));
    ParamAdd(strParam, "ColorG", string(ColorG));
    ParamAdd(strParam, "ColorB", string(ColorB));
    ParamAdd(strParam, "ItemID", string(ItemID));
    // End:0x143
    if(-1 != InStr(Text, "ItemID="))
    {
        Text = Mid(Text, 0, InStr(Text, "ItemID="));
    }
    ParamAdd(strParam, "Msg", Text);
    HandleChatmessage(strParam);
    return;
}

function HandleChatmessage(string param)
{
    local int nTmp;
    local EChatType Type;
    local ESystemMsgType systemType;
    local string Text;
    local Color Color;
    local WhispAlertWnd script;

    script = WhispAlertWnd(GetScript("WhispAlertWnd"));
    ParseInt(param, "Type", nTmp);
    Type = EChatType(nTmp);
    ParseString(param, "Msg", Text);
    ParseInt(param, "ColorR", nTmp);
    Color.R = byte(nTmp);
    ParseInt(param, "ColorG", nTmp);
    Color.G = byte(nTmp);
    ParseInt(param, "ColorB", nTmp);
    Color.B = byte(nTmp);
    Color.A = byte(255);
    // End:0x11E
    if(Type == 5)
    {
        ParseInt(param, "SysType", nTmp);
        systemType = ESystemMsgType(nTmp);        
    }
    else
    {
        systemType = ESystemMsgType(0);
    }
    // End:0x153
    if(CheckFilter(Type, 0, systemType))
    {
        NormalChat.AddString(Text, Color);
    }
    // End:0x181
    if(CheckFilter(Type, 2, systemType))
    {
        PartyChat.AddString(Text, Color);
    }
    // End:0x1AF
    if(CheckFilter(Type, 3, systemType))
    {
        ClanChat.AddString(Text, Color);
    }
    // End:0x1DC
    if(CheckFilter(Type, 1, systemType))
    {
        TradeChat.AddString(Text, Color);
    }
    // End:0x20A
    if(CheckFilter(Type, 4, systemType))
    {
        AllyChat.AddString(Text, Color);
    }
    // End:0x238
    if(CheckFilter(Type, 5, systemType))
    {
        SystemMsg.AddString(Text, Color);
    }
    // End:0x260
    if((Type == 15) && m_NoUnionCommanderMessage == 0)
    {
        ShowUnionCommanderMessgage(Text);
    }
    // End:0x270
    if(Type != 2)
    {
        return;
    }
    script.WhispMessage(param);
    return;
}

function ShowUnionCommanderMessgage(string Msg)
{
    local string strParam, MsgTemp, MsgTemp2;
    local int MaxLength;

    MaxLength = Len(Msg);
    // End:0x55
    if(MaxLength > 35)
    {
        MsgTemp = Left(Msg, 35);
        MsgTemp2 = Right(Msg, MaxLength - 35);
        Msg = (MsgTemp $ "#") $ MsgTemp2;
    }
    Debug(Msg);
    // End:0x17E
    if(Len(Msg) > 0)
    {
        ParamAdd(strParam, "MsgType", string(1));
        ParamAdd(strParam, "WindowType", string(8));
        ParamAdd(strParam, "FontType", string(0));
        ParamAdd(strParam, "BackgroundType", string(0));
        ParamAdd(strParam, "LifeTime", string(5000));
        ParamAdd(strParam, "AnimationType", string(1));
        ParamAdd(strParam, "Msg", Msg);
        ParamAdd(strParam, "MsgColorR", string(255));
        ParamAdd(strParam, "MsgColorG", string(150));
        ParamAdd(strParam, "MsgColorB", string(149));
        ExecuteEvent(140, strParam);
    }
    return;
}

function bool CheckFilter(EChatType Type, int WindowType, ESystemMsgType systemType)
{
    if (!(WindowType >= 0 && WindowType < 5) && WindowType != 5)
    {
        Debug("ChatWnd: Error invalid windowType " $ string(WindowType));
        return false;
    }

    switch (Type)
    {
        case EChatType(8):
            return m_filterInfo[WindowType].bTrade != 0;

        case EChatType(0):
            return m_filterInfo[WindowType].bNormal != 0;

        case EChatType(4):
            return m_filterInfo[WindowType].bClan != 0;

        case EChatType(3):
            return m_filterInfo[WindowType].bParty != 0;

        case EChatType(1):
            return m_filterInfo[WindowType].bShout != 0;

        case EChatType(2):
            return m_filterInfo[WindowType].bWhisper != 0;

        case EChatType(9):
            return m_filterInfo[WindowType].bAlly != 0;

        case EChatType(17):
            return m_filterInfo[WindowType].bHero != 0;

        case EChatType(10):
        case EChatType(18):
        case EChatType(6):
        case EChatType(7):
            return true;

        case EChatType(16):
        case EChatType(15):
            return m_filterInfo[WindowType].bUnion != 0;

        case EChatType(5):
            if ((systemType == 2) || (systemType == 6))
                return true;

            if (WindowType == 5)
            {
                if (systemType == 3)
                    return GetOptionBool("Game", "SystemMsgWndDamage");

                if (systemType == 7)
                    return GetOptionBool("Game", "SystemMsgWndExpendableItem");

                return (systemType == 1 || systemType == 0);
            }
            return m_filterInfo[WindowType].bSystem != 0 && 
                   (systemType == 3 && m_filterInfo[WindowType].bDamage != 0) ||
                   (systemType == 7 && m_filterInfo[WindowType].bUseitem != 0);

        default:
            return false;
    }
}


function InitFilterInfo()
{
    local int i, tempVal;

    SetDefaultFilterValue();
    i = 0;
    J0x0D:

    // End:0x3B5 [Loop If]
    if(i < 5)
    {
        // End:0x60
        if(GetINIBool(m_sectionName[i], "system", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bSystem = tempVal;
        }
        // End:0xA5
        if(GetINIBool(m_sectionName[i], "chat", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bChat = tempVal;
        }
        // End:0xEC
        if(GetINIBool(m_sectionName[i], "normal", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bNormal = tempVal;
        }
        // End:0x132
        if(GetINIBool(m_sectionName[i], "shout", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bShout = tempVal;
        }
        // End:0x179
        if(GetINIBool(m_sectionName[i], "pledge", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bClan = tempVal;
        }
        // End:0x1BF
        if(GetINIBool(m_sectionName[i], "party", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bParty = tempVal;
        }
        // End:0x206
        if(GetINIBool(m_sectionName[i], "market", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bTrade = tempVal;
        }
        // End:0x24B
        if(GetINIBool(m_sectionName[i], "tell", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bWhisper = tempVal;
        }
        // End:0x292
        if(GetINIBool(m_sectionName[i], "damage", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bDamage = tempVal;
        }
        // End:0x2D7
        if(GetINIBool(m_sectionName[i], "ally", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bAlly = tempVal;
        }
        // End:0x320
        if(GetINIBool(m_sectionName[i], "useitems", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bUseitem = tempVal;
        }
        // End:0x365
        if(GetINIBool(m_sectionName[i], "hero", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bHero = tempVal;
        }
        // End:0x3AB
        if(GetINIBool(m_sectionName[i], "union", tempVal, "chatfilter.ini"))
        {
            m_filterInfo[i].bUnion = tempVal;
        }
        ++i;
        // [Loop Continue]
        goto J0x0D;
    }
    SetDefaultFilterOn();
    // End:0x3F5
    if(GetINIBool("global", "command", tempVal, "chatfilter.ini"))
    {
        m_NoUnionCommanderMessage = tempVal;
    }
    return;
}

