}

function Color xxGetColorito(string param)
{
    local Color get;

    get.A = byte(255);
    switch(param)
    {
        // End:0x4F
        case "Yellow":
            get.R = byte(255);
            get.G = byte(255);
            get.B = 0;
            // End:0x191
            break;
        // End:0x84
        case "System":
            get.R = 176;
            get.G = 155;
            get.B = 121;
            // End:0x191
            break;
        // End:0xB8
        case "Amber":
            get.R = 218;
            get.G = 165;
            get.B = 32;
            // End:0x191
            break;
        // End:0xF2
        case "White":
            get.R = byte(255);
            get.G = byte(255);
            get.B = byte(255);
            // End:0x191
            break;
        // End:0xtukasaxa2
        case "Dim":
            get.R = 177;
            get.G = 173;
            get.B = 172;
            // End:0x191
            break;
        // End:0x15E
        case "Magenta":
            get.R = byte(255);
            get.G = 0;
            get.B = byte(255);
            // End:0x191
            break;
        // End:0xFFFF
        default:
            get.R = byte(255);
            get.G = byte(255);
            get.B = byte(255);
            // End:0x191
            break;
            break;
    }
    return get;

}

