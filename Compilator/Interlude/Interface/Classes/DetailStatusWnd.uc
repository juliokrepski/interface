 function UpdateHPBar(int Value, int MaxValue)
 {
     local int Size;
 
     Size = 0;
     // End:0x3F
     if(MaxValue > 0)
     {
         Size = 132;
         // End:0x3F
         if(Value < MaxValue)
         {
             Size = (132 * Value) / MaxValue;
         }
     }
     Class'UIAPI_WINDOW'.static.SetWindowSize(m_WindowName $ ".texHP", Size, 12);
     return;
 }
 
 function UpdateMPBar(int Value, int MaxValue)
 {
     local int Size;
 
     Size = 0;
     // End:0x3F
     if(MaxValue > 0)
     {
         Size = 132;
         // End:0x3F
         if(Value < MaxValue)
         {
             Size = (132 * Value) / MaxValue;
         }
     }
     Class'UIAPI_WINDOW'.static.SetWindowSize(m_WindowName $ ".texMP", Size, 12);
     return;
 }
 
 function UpdateEXPBar(int Value, int MaxValue)
 {
     local int Size;
 
     Size = 0;
     // End:0x45
     if(MaxValue > 0)
     {
         Size = 297;
         // End:0x45
         if(Value < MaxValue)
         {
             Size = (297 * Value) / MaxValue;
         }
     }
     Class'UIAPI_WINDOW'.static.SetWindowSize(m_WindowName $ ".texEXP", Size, 12);
     return;
 }
 
 function UpdateCPBar(int Value, int MaxValue)
 {
     local int Size;
 
     Size = 0;
     // End:0x3F
     if(MaxValue > 0)
     {
         Size = 132;
         // End:0x3F
         if(Value < MaxValue)
         {
             Size = (132 * Value) / MaxValue;
         }
     }
     Class'UIAPI_WINDOW'.static.SetWindowSize(m_WindowName $ ".texCP", Size, 12);
     return;
 }
 
 function UpdateWeightBar(int Value, int MaxValue)
 {
     local int Size;
     local float fTmp;
     local string strName;
 
     Size = 0;
     // End:0x17B
     if(MaxValue > 0)
     {
         fTmp = (100 * float(Value)) / float(MaxValue);
         // End:0x6F
         if(fTmp <= 50)
         {
             strName = "L2UI_CH3.PlayerStatusWnd.ps_weightbar1";            
         }
         else
         {
             // End:0xC0
             if((fTmp > 50) && fTmp <= 66.66)
             {
                 strName = "L2UI_CH3.PlayerStatusWnd.ps_weightbar2";                
             }
             else
             {
                 // End:0x111
                 if((fTmp > 66.66) && fTmp <= 80)
                 {
                     strName = "L2UI_CH3.PlayerStatusWnd.ps_weightbar3";                    
                 }
                 else
                 {
                     // End:0x14E
                     if(fTmp > 80)
                     {
                         strName = "L2UI_CH3.PlayerStatusWnd.ps_weightbar4";
                     }
                 }
             }
         }
         Size = 132;
         // End:0x17B
         if(Value < MaxValue)
         {
             Size = (132 * Value) / MaxValue;
         }
     }
     Class'UIAPI_WINDOW'.static.SetWindowSize(m_WindowName $ ".texWeight", Size, 12);
     return;
 }
 
 defaultproperties
