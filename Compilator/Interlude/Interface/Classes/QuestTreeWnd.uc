function HandleLanguageChanged()
{
    // End:0x1D
    if(Class'UIAPI_WINDOW'.static.IsShowWindow(m_WindowName))
    {
        ShowQuestList();
    }
    return;
}

function HandleAddAlarm()
{
    local int i;
    local bool isRequestToServer;

    isRequestToServer = true;
    GetNodeInfo_Alarm();
    i = 0;
    J0x15:

    // End:0xCF [Loop If]
    if(i < m_arrItemNodeName.Length)
    {
        // End:0xC5
        if(m_arrItemQuestID[i] == QuestID_Alarm)
        {
            m_scriptAlarm.isClickedAdd = true;
            // End:0x96
            if(m_arrItemID[i] >= 1000000)
            {
                m_scriptAlarm.AddQuestAlarmExpand(QuestID_Alarm, QuestLevel_Alarm, m_arrItemID[i], 0, m_arrItemNumList[i]);
                // [Explicit Continue]
                goto J0xC5;
                // [Explicit Continue]
                goto J0xC5;
            }
            m_scriptAlarm.AddQuestAlarm(QuestID_Alarm, QuestLevel_Alarm, m_arrItemID[i], m_arrItemNumList[i]);
        }
        J0xC5:

        i++;
        // [Loop Continue]
        goto J0x15;
    }
    ButtonEnableCheck();
    return;
}

function HandleDeleteAlarm()
{
    local int i;

    GetNodeInfo_Alarm();
    i = 0;
    J0x0D:

    // End:0x50 [Loop If]
    if(i < m_arrItemNodeName.Length)
    {
        // End:0x46
        if(m_arrItemQuestID[i] == QuestID_Alarm)
        {
            m_scriptAlarm.DeleteQuestAlarm(QuestID_Alarm);
        }
        i++;
        // [Loop Continue]
        goto J0x0D;
    }
    ButtonEnableCheck();
    return;
}

function GetNodeInfo_Alarm()
{
    local string strNodeName, strTargetNode;
    local int i;
    local array<string> arrSplit;
    local int SplitCount;
    local string strChildList;

    strNodeName = GetExpandedNode();
    strChildList = Class'UIAPI_TREECTRL'.static.GetChildNode(m_WindowName $ ".MainTree", strNodeName);
    // End:0x75
    if(Len(strChildList) > 0)
    {
        SplitCount = Split(strChildList, "|", arrSplit);
        strTargetNode = arrSplit[SplitCount - 1];        
    }
    else
    {
        SetQuestOff();
        return;
    }
    arrSplit.Remove(0, arrSplit.Length);
    SplitCount = Split(strTargetNode, ".", arrSplit);
    i = 0;
    J0xAA:

    // End:0x124 [Loop If]
    if(i < SplitCount)
    {
        switch(i)
        {
            // End:0xC7
            case 0:
                // End:0x11A
                break;
            // End:0xE1
            case 1:
                QuestID_Alarm = int(arrSplit[i]);
                // End:0x11A
                break;
            // End:0xFC
            case 2:
                QuestLevel_Alarm = int(arrSplit[i]);
                // End:0x11A
                break;
            // End:0x117
            case 2:
                QuestEnd_Alarm = int(arrSplit[i]);
                // End:0x11A
                break;
            // End:0xFFFF
            default:
                break;
        }
        i++;
        // [Loop Continue]
        goto J0xAA;
    }
 
}

function UpdateItemCountWhenAdd(int ClassID)
{
    local int i, j, nPos, itemCount;
    local array<string> arrSplit;
    local int SplitCount;

    // End:0x0E
    if(QuestAutoAlarm == true)
    {
        return;
    }
    i = 0;
    J0x15:

    // End:0x1A8 [Loop If]
    if(i < m_arrItemID.Length)
    {
        // End:0x19E
        if((ClassID == 0) || ClassID == m_arrItemID[i])
        {
            nPos = InStr(m_arrItemString[i], "%s");
            // End:0x19E
            if(nPos > -1)
            {
                // End:0x19E
                if(ClassID != 0)
                {
                    arrSplit.Remove(0, arrSplit.Length);
                    SplitCount = Split(m_arrItemNodeName[i], ".", arrSplit);
                    j = 0;
                    J0xAB:

                    // End:0x10A [Loop If]
                    if(j < SplitCount)
                    {
                        switch(j)
                        {
                            // End:0xC8
                            case 0:
                                // End:0x100
                                break;
                            // End:0xE2
                            case 1:
                                QuestID_Alarm = int(arrSplit[j]);
                                // End:0x100
                                break;
                            // End:0xFD
                            case 2:
                                QuestLevel_Alarm = int(arrSplit[j]);
                                // End:0x100
                                break;
                            // End:0xFFFF
                            default:
                                break;
                        }
                        j++;
                        // [Loop Continue]
                        goto J0xAB;
                    }
                    j = 0;
                    J0x111:

                    // End:0x198 [Loop If]
                    if(j < m_arrItemNodeName.Length)
                    {
                        // End:0x18E
                        if(m_arrItemQuestID[j] == QuestID_Alarm)
                        {
                            itemCount = GetInventoryItemCount(ClassID);
                            // End:0x18E
                            if(itemCount != 0)
                            {
                                OMG(string(QuestID_Alarm));
                                m_scriptAlarm.AddQuestAlarm(QuestID_Alarm, QuestLevel_Alarm, m_arrItemID[j], m_arrItemNumList[j]);
                            }
                        }
                        j++;
                        // [Loop Continue]
                        goto J0x111;
                    }
                    ButtonEnableCheck();
                }
            }
        }
        i++;
        // [Loop Continue]
        goto J0x15;
    }
    return;
}

function ButtonEnableCheck()
{
    local int i, QuestIDSlot;
    local bool isCanBeAddAlarm;

    GetNodeInfo_Alarm();
    isCanBeAddAlarm = false;
    i = 0;
    J0x15:

    // End:0x4F [Loop If]
    if(i < m_arrItemNodeName.Length)
    {
        // End:0x45
        if(m_arrItemQuestID[i] == QuestID_Alarm)
        {
            isCanBeAddAlarm = true;
            // [Explicit Break]
            goto J0x4F;
        }
        i++;
        // [Loop Continue]
        goto J0x15;
    }
    J0x4F:

    QuestIDSlot = m_scriptAlarm.QuestSlotIdx(QuestID_Alarm);
    // End:0x95
    if(QuestID_Alarm == 0)
    {
        m_btnAddAlarm.DisableWindow();
        m_btnDeleteAlarm.DisableWindow();        
    }
    else
    {
        // End:0xDF
        if(QuestIDSlot < 0)
        {
            // End:0xBE
            if(isCanBeAddAlarm == true)
            {
                m_btnAddAlarm.EnableWindow();                
            }
            else
            {
                m_btnAddAlarm.DisableWindow();
            }
            m_btnDeleteAlarm.DisableWindow();            
        }
        else
        {
            m_btnAddAlarm.DisableWindow();
            m_btnDeleteAlarm.EnableWindow();
        }
    }
    return;
}

defaultproperties
{
    m_WindowName="QuestTreeWnd"
}