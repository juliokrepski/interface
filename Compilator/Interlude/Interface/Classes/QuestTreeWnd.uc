var int QuestID_Alarm;
var int QuestLevel_Alarm;
var int QuestEnd_Alarm;
var bool QuestAutoAlarm;

function OnLoad()
{
    RegisterEvent(700);
    RegisterEvent(710);
    RegisterEvent(720);
    RegisterEvent(730);
    RegisterEvent(1710);
    RegisterEvent(2600);
    RegisterEvent(2610);
    RegisterEvent(1900);
    m_scriptAlarm = QuestAlarmWnd(GetScript("QuestAlarmWnd"));
    m_QuestTooltip = TextureHandle(GetHandle(m_WindowName $ ".QuestToolTip"));
    m_btnAddAlarm = GetButtonHandle("QuestTreeWnd.btnAddAlarm");
    m_btnDeleteAlarm = GetButtonHandle("QuestTreeWnd.btnDeleteAlarm");
    m_btnAddAlarm.DisableWindow();
    m_btnDeleteAlarm.DisableWindow();
    InitQuestTooltip();
    m_QuestNum = 0;
    return;
}

function OnShow()
{
    ShowQuestList();
    return;
}

function OnClickButton(string strID)
{
    switch(strID)
    {
        // End:0x22
        case "btnClose":
            HideWindow(m_WindowName);
            // End:0x70
            break;
        // End:0x38
        case "btnAbort":
            HandleQuestCancel();
            // End:0x70
            break;
        // End:0x51
        case "btnAddAlarm":
            HandleAddAlarm();
            // End:0x70
            break;
        // End:0x6D
        case "btnDeleteAlarm":
            HandleDeleteAlarm();
            // End:0x70
            break;
        // End:0xFFFF
        default:
            break;
    }
    // End:0x8A
    if(Left(strID, 4) == "root")
    {
        UpdateTargetInfo();
    }
    return;
}

function OnClickCheckBox(string strID)
{
    switch(strID)
    {
        // End:0x21
        case "chkNpcPosBox":
            UpdateTargetInfo();
            // End:0x24
            break;
        // End:0xFFFF
        default:
            break;
    }
    return;
}

function Clear()
{
    m_QuestNum = 0;
    UpdateQuestCount();
    m_OldQuestID = -1;
    m_CurNodeName = "";
    m_DeleteQuestID = 0;
    m_DeleteNodeName = "";
    m_arrItemNodeName.Remove(0, m_arrItemNodeName.Length);
    m_arrItemString.Remove(0, m_arrItemString.Length);
    m_arrItemID.Remove(0, m_arrItemID.Length);
    m_arrItemQuestID.Remove(0, m_arrItemQuestID.Length);
    m_arrItemLevel.Remove(0, m_arrItemLevel.Length);
    m_arrItemNumList.Remove(0, m_arrItemNumList.Length);
    Class'UIAPI_TREECTRL'.static.Clear(m_WindowName $ ".MainTree");
    return;
}

function ShowQuestList()
{
    Class'QuestAPI'.static.RequestQuestList();
    return;
}

function InitTree()
{
    local XMLTreeNodeInfo infNode;
    local string strRetName;

    Clear();
    infNode.strName = "root";
    infNode.nOffSetX = 3;
    infNode.nOffSetY = 5;
    strRetName = Class'UIAPI_TREECTRL'.static.InsertNode(m_WindowName $ ".MainTree", "", infNode);
    // End:0xA3
    if(Len(strRetName) < 1)
    {
        Log("ERROR: Can't insert root node. Name: " $ infNode.strName);
        return;
    }
    return;
}

function HandleQuestListStart()
{
    InitTree();
    return;
}

function HandleQuestList(string a_Param)
{
    local int QuestID, Level, Completed;

    ParseInt(a_Param, "QuestID", QuestID);
    ParseInt(a_Param, "Level", Level);
    ParseInt(a_Param, "Completed", Completed);
    // End:0x7B
    if(m_OldQuestID != QuestID)
    {
        m_QuestNum++;
        AddQuestInfo("", QuestID, Level, Completed);        
    }
    else
    {
        AddQuestInfo(m_CurNodeName, QuestID, Level, Completed);
    }
    m_OldQuestID = QuestID;
    return;
}

function HandleQuestListEnd()
{
    local int i, j;
    local bool isExist;
    local int tempItemID;

    UpdateQuestCount();
    UpdateItemCount(0);
    i = 0;
    J0x14:

    // End:0xCC [Loop If]
    if(i < 25)
    {
        isExist = false;
        tempItemID = m_scriptAlarm.QuestItemNameID[i];
        // End:0xC2
        if(tempItemID != -1)
        {
            j = 0;
            J0x58:

            // End:0x8F [Loop If]
            if(j < m_arrItemID.Length)
            {
                // End:0x85
                if(m_arrItemID[j] == tempItemID)
                {
                    isExist = true;
                }
                j++;
                // [Loop Continue]
                goto J0x58;
            }
            // End:0xC2
            if(isExist == false)
            {
                m_scriptAlarm.DeleteQuestAlarm(m_scriptAlarm.QuestAlarmNameID[i / 5]);
            }
        }
        i++;
        // [Loop Continue]
        goto J0x14;
    }
    ButtonEnableCheck();
    return;
}

function OnEvent(int Event_ID, string param)
{
    local int ClassID;

    // End:0x18
    if(Event_ID == 700)
    {
        HandleQuestListStart();        
    }
    else
    {
        // End:0x35
        if(Event_ID == 710)
        {
            HandleQuestList(param);            
        }
        else
        {
            // End:0x4D
            if(Event_ID == 720)
            {
                HandleQuestListEnd();                
            }
            else
            {
                // End:0x6A
                if(Event_ID == 730)
                {
                    HandleQuestSetCurrentID(param);                    
                }
                else
                {
                    // End:0xC0
                    if((Event_ID == 2600) || Event_ID == 2610)
                    {
                        ParseInt(param, "classID", ClassID);
                        UpdateItemCount(ClassID);
                        // End:0xBD
                        if(Event_ID == 2610)
                        {
                        }                        
                    }
                    else
                    {
                        // End:0x139
                        if(Event_ID == 1710)
                        {
                            // End:0x136
                            if(DialogIsMine())
                            {
                                // End:0x136
                                if((DialogGetID()) == 0)
                                {
                                    Class'QuestAPI'.static.RequestDestroyQuest(m_DeleteQuestID);
                                    SetQuestOff();
                                    Class'UIAPI_TREECTRL'.static.DeleteNode(m_WindowName $ ".MainTree", m_DeleteNodeName);
                                    m_DeleteQuestID = 0;
                                    m_DeleteNodeName = "";                                    
                                }
                            }                            
                        }
                        else
                        {
                            // End:0x14E
                            if(Event_ID == 1900)
                            {
                                HandleLanguageChanged();
                            }
                        }
                    }
                }
            }
        }
    }
    return;
}

function HandleQuestSetCurrentID(string param)
{
    local string strNodeName, strChildList;
    local int RecentlyAddedQuestID, SplitCount;
    local array<string> arrSplit;

    // End:0x20
    if(!ParseInt(param, "QuestID", RecentlyAddedQuestID))
    {
        return;
    }
    // End:0xF0
    if(RecentlyAddedQuestID > 0)
    {
        strNodeName = "root." $ string(RecentlyAddedQuestID);
        Class'UIAPI_TREECTRL'.static.SetExpandedNode(m_WindowName $ ".MainTree", strNodeName, true);
        strChildList = Class'UIAPI_TREECTRL'.static.GetChildNode(m_WindowName $ ".MainTree", strNodeName);
        // End:0xEA
        if(Len(strChildList) > 0)
        {
            SplitCount = Split(strChildList, "|", arrSplit);
            Class'UIAPI_TREECTRL'.static.SetExpandedNode(m_WindowName $ ".MainTree", arrSplit[SplitCount - 1], true);
        }
        UpdateTargetInfo();
    }
    return;
}

function UpdateItemCount(int ClassID, optional int a_ItemCount)
{
    local int i, nPos, itemCount;
    local string strTmp;

    i = 0;
    J0x07:

    // End:0x162 [Loop If]
    if(i < m_arrItemID.Length)
    {
        // End:0x158
        if((ClassID == 0) || ClassID == m_arrItemID[i])
        {
            itemCount = a_ItemCount;
            // End:0x5D
            if(a_ItemCount == -1)
            {
                itemCount = 0;                
            }
            else
            {
                // End:0x7F
                if(a_ItemCount == 0)
                {
                    itemCount = GetInventoryItemCount(m_arrItemID[i]);
                }
            }
            nPos = InStr(m_arrItemString[i], "%s");
            // End:0x158
            if(nPos > -1)
            {
                strTmp = (Left(m_arrItemString[i], nPos) $ string(itemCount)) $ Mid(m_arrItemString[i], nPos + 2);
                Class'UIAPI_TREECTRL'.static.SetNodeItemText(m_WindowName $ ".MainTree", m_arrItemNodeName[i], m_arrItemID.Length - i, strTmp);
                // End:0x139
                if(itemCount < 0)
                {
                    itemCount = itemCount * -1;
                }
                m_scriptAlarm.UpdateAlarmItem(m_arrItemID[i], itemCount);
            }
        }
        i++;
        // [Loop Continue]
        goto J0x07;
    }
    return;
}

function UpdateQuestCount()
{
    Class'UIAPI_TEXTBOX'.static.SetText(m_WindowName $ ".txtQuestNum", ((("(" $ string(m_QuestNum)) $ "/") $ string(25)) $ ")");
    return;
}

function UpdateTargetInfo()
{
    local int i;
    local array<string> arrSplit;
    local int SplitCount, QuestID, Level, Completed;
    local string strChildList, strTargetNode, strNodeName, strTargetName;
    local Vector vTargetPos;
    local bool bOnlyMinimap;

    // End:0x32
    if(!Class'UIAPI_CHECKBOX'.static.IsChecked(m_WindowName $ ".chkNpcPosBox"))
    {
        SetQuestOff();
        return;
    }
    strNodeName = GetExpandedNode();
    // End:0x53
    if(Len(strNodeName) < 1)
    {
        SetQuestOff();
        return;
    }
    strChildList = Class'UIAPI_TREECTRL'.static.GetChildNode(m_WindowName $ ".MainTree", strNodeName);
    // End:0xBC
    if(Len(strChildList) > 0)
    {
        SplitCount = Split(strChildList, "|", arrSplit);
        strTargetNode = arrSplit[SplitCount - 1];        
    }
    else
    {
        SetQuestOff();
        return;
    }
    arrSplit.Remove(0, arrSplit.Length);
    SplitCount = Split(strTargetNode, ".", arrSplit);
    i = 0;
    J0xF1:

    // End:0x16B [Loop If]
    if(i < SplitCount)
    {
        switch(i)
        {
            // End:0x10E
            case 0:
                // End:0x161
                break;
            // End:0x128
            case 1:
                QuestID = int(arrSplit[i]);
                // End:0x161
                break;
            // End:0x143
            case 2:
                Level = int(arrSplit[i]);
                // End:0x161
                break;
            // End:0x15E
            case 2:
                Completed = int(arrSplit[i]);
                // End:0x161
                break;
            // End:0xFFFF
            default:
                break;
        }
        i++;
        // [Loop Continue]
        goto J0xF1;
    }
    // End:0x252
    if((QuestID > 0) && Level > 0)
    {
        strTargetName = Class'UIDATA_QUEST'.static.GetTargetName(QuestID, Level);
        vTargetPos = Class'UIDATA_QUEST'.static.GetTargetLoc(QuestID, Level);
        // End:0x24C
        if((Completed == 0) && Len(strTargetName) > 0)
        {
            bOnlyMinimap = Class'UIDATA_QUEST'.static.IsMinimapOnly(QuestID, Level);
            // End:0x228
            if(bOnlyMinimap)
            {
                Class'QuestAPI'.static.SetQuestTargetInfo(true, false, false, strTargetName, vTargetPos, QuestID);                
            }
            else
            {
                Class'QuestAPI'.static.SetQuestTargetInfo(true, true, true, strTargetName, vTargetPos, QuestID);
            }            
        }
        else
        {
            SetQuestOff();
        }
    }
    ButtonEnableCheck();
    return;
}

function SetQuestOff()
{
    local Vector vVector;

    Class'QuestAPI'.static.SetQuestTargetInfo(false, false, false, "", vVector, 0);
    return;
}

function string GetExpandedNode()
{
    local array<string> arrSplit;
    local int SplitCount;
    local string strNodeName;

    strNodeName = Class'UIAPI_TREECTRL'.static.GetExpandedNode(m_WindowName $ ".MainTree", "root");
    SplitCount = Split(strNodeName, "|", arrSplit);
    // End:0x5E
    if(SplitCount > 0)
    {
        strNodeName = arrSplit[0];
    }
    return strNodeName;

}

function HandleQuestCancel()
{
    local array<string> arrSplit;
    local int SplitCount;
    local string strNodeName;

    m_DeleteQuestID = 0;
    m_DeleteNodeName = "";
    strNodeName = GetExpandedNode();
    SplitCount = Split(strNodeName, "|", arrSplit);
    // End:0x97
    if(SplitCount > 0)
    {
        strNodeName = arrSplit[0];
        arrSplit.Remove(0, arrSplit.Length);
        SplitCount = Split(strNodeName, ".", arrSplit);
        // End:0x97
        if(SplitCount > 1)
        {
            m_DeleteQuestID = int(arrSplit[1]);
            m_DeleteNodeName = strNodeName;
        }
    }
    // End:0xC1
    if(Len(m_DeleteNodeName) < 1)
    {
        DialogShow(DIALOG_Notice, GetSystemMessage(1201));
        DialogSetID(1);        
    }
    else
    {
        DialogShow(DIALOG_Warning, GetSystemMessage(182));
        DialogSetID(0);
    }
    return;
}

