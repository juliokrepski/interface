class QuitReportDrawerWnd extends UICommonAPI;

const  QuitReportItemList = "QuitReportWnd.ItemList";
const  QuitReportConst = "QuitReportWnd.";
const  ItemListConst = "ItemList";

var WindowHandle Me;
var ListCtrlHandle zzItemListCtrl;
var ButtonHandle zzcloseBtn;
var int zzitemIndex;
var bool zzisReverseSort;
var array<ItemInfo> zzgetItemInfoArray;
var L2Util util;
var InventoryWnd zzinventoryWndScript;
var QuitReportWnd zzQuitReportWndScript;

function OnLoad()
{
    Me = GetWindowHandle("QuitReportDrawerWnd");
    zzItemListCtrl = 	ListCtrlHandle("QuitReportDrawerWnd.InstanceDungeon_ListCtrl");
    zzcloseBtn = GetButtonHandle("QuitReportDrawerWnd.EnsoulInfoBtn");
    util = L2Util(GetScript("L2Util"));
    zzinventoryWndScript = InventoryWnd(GetScript("inventoryWnd"));
    zzQuitReportWndScript = QuitReportWnd(GetScript("QuitReportWnd"));
    Init();
    return;
}

function OnShow()
{
    updateList();
    return;
}

function OnClickButton(string Name)
{
    switch(Name)
    {
        // End:0x20
        case "CloseButton":
            OnEnsoulInfoBtnClick();
            // End:0xA2
            break;
        // End:0x5F
        case "OrderByName":
            SetOrderStat();
            zzgetItemInfoArray = util.sortByNameFirstName(zzgetItemInfoArray, zzisReverseSort);
            updateList();
            // End:0xA2
            break;
        // End:0x9F
        case "OrderByCount":
            SetOrderStat();
            zzgetItemInfoArray = util.sortByCount(zzgetItemInfoArray, zzisReverseSort);
            updateList();
            // End:0xA2
            break;
        // End:0xFFFF
        default:
            break;
    }
    return;
}

function SetOrderStat()
{
    // End:0x16
    if(!zzisReverseSort)
    {
        zzisReverseSort = true;        
    }
    else
    {
        zzisReverseSort = false;
    }
    return;
}

function OnEnsoulInfoBtnClick()
{
    zzQuitReportWndScript.setDrawerButtonState(true);
    Me.HideWindow();
    return;
}

function externalAddItem(ItemInfo addItemInfo)
{
    // End:0x21
    if(IsStackableItem(addItemInfo.ConsumeType))
    {
        sumStackableItem(addItemInfo);        
    }
    else
    {
        zzgetItemInfoArray.Length = zzgetItemInfoArray.Length + 1;
        zzgetItemInfoArray[zzgetItemInfoArray.Length - 1] = addItemInfo;
    }
    // End:0x5E
    if(Me.IsShowWindow())
    {
        updateList();
    }
    return;
}

function int getTotalItemCount()
{
    local int zzadenItem, zzitemLen, zzi;

    zzadenItem = 0;
    zzitemLen = zzgetItemInfoArray.Length;
    zzi = 0;
    J0x1A:

    // End:0x64 [Loop If]
    if(zzi < zzitemLen)
    {
        // End:0x5A
        if(zzgetItemInfoArray.Length > 0)
        {
            // End:0x5A
            if(zzgetItemInfoArray[zzi].ClassID == 57)
            {
                zzadenItem = -1;
                // [Explicit Break]
                goto J0x64;
            }
        }
        zzi++;
        // [Loop Continue]
        goto J0x1A;
    }
    J0x64:

    return zzgetItemInfoArray.Length + zzadenItem;
    
}

function Init()
{
    // End:0x19
    if(zzgetItemInfoArray.Length > 0)
    {
        zzgetItemInfoArray.Remove(0, zzgetItemInfoArray.Length);
    }
    zzitemIndex = 0;
    zzItemListCtrl.DeleteAllItem();
    TreeClear("QuitReportWnd.ItemList");
    TreeInsertRootNode("QuitReportWnd.ItemList", "ItemList", "", 0, 0);
    return;
}

function sumStackableItem(ItemInfo addItemInfo)
{
    local int zzi;
    local ItemInfo zzbeforeItemInfo;
    local bool zzbAdd;

    zzi = 0;
    J0x07:

    // End:0xE7 [Loop If]
    if(zzi < zzgetItemInfoArray.Length)
    {
        // End:0xDD
        if(zzgetItemInfoArray[zzi].ClassID == addItemInfo.ClassID)
        {
            zzinventoryWndScript.getInventoryItemInfo(addItemInfo.ClassID, zzbeforeItemInfo, true);
            // End:0xD2
            if(zzbeforeItemInfo.ItemNum < addItemInfo.ItemNum)
            {
                addItemInfo.ItemNum = zzgetItemInfoArray[zzi].ItemNum + (addItemInfo.ItemNum - zzbeforeItemInfo.ItemNum);
                zzgetItemInfoArray.Remove(zzi, 1);
                zzgetItemInfoArray.Length = zzgetItemInfoArray.Length + 1;
                zzgetItemInfoArray[zzgetItemInfoArray.Length - 1] = addItemInfo;
            }
            zzbAdd = true;
            // [Explicit Break]
            goto J0xE7;
        }
        zzi++;
        // [Loop Continue]
        goto J0x07;
    }
    J0xE7:

    // End:0x1B3
    if(zzbAdd == false)
    {
        zzinventoryWndScript.getInventoryItemInfo(addItemInfo.ClassID, zzbeforeItemInfo, true);
        // End:0x1B3
        if(zzbeforeItemInfo.ItemNum < addItemInfo.ItemNum)
        {
            // End:0x16D
            if(zzgetItemInfoArray.Length > 0)
            {
                addItemInfo.ItemNum = zzgetItemInfoArray[zzi].ItemNum + (addItemInfo.ItemNum - zzbeforeItemInfo.ItemNum);                
            }
            else
            {
                addItemInfo.ItemNum = addItemInfo.ItemNum - zzbeforeItemInfo.ItemNum;
            }
            zzgetItemInfoArray.Length = zzgetItemInfoArray.Length + 1;
            zzgetItemInfoArray[zzgetItemInfoArray.Length - 1] = addItemInfo;
        }
    }
    return;
}

function updateList()
{
    local int zzi;

    zzItemListCtrl.DeleteAllItem();
    zzitemIndex = 0;
    // End:0x72
    if(zzgetItemInfoArray.Length > 0)
    {
        zzi = zzgetItemInfoArray.Length - 1;
        J0x31:

        // End:0x72 [Loop If]
        if(zzi > -1)
        {
            // End:0x68
            if(zzgetItemInfoArray[zzi].ClassID != 57)
            {
                ack(zzgetItemInfoArray[zzi]);
            }
            zzi--;
            // [Loop Continue]
            goto J0x31;
        }
    }
    zzQuitReportWndScript.UpdateUserInfoHandler();
    return;
}

function ack(ItemInfo Info)
{
    local string zzstrRetName, zzAdditionalName, zzfullNameString, zzitemNumEasyRead;
    local int zztxtWidth, zztxtHeight;

    zzfullNameString = Info.Name;
    zzAdditionalName = Class'UIDATA_ITEM'.static.GetItemAdditionalName(Info.ClassID);
    // End:0x7E
    if((Mid(zzfullNameString, Len(zzfullNameString) - 3, 1) == "[") && Mid(zzfullNameString, Len(zzfullNameString) - 1, 1) == "]")
    {
        zzfullNameString = Left(zzfullNameString, Len(zzfullNameString) - 3);
    }
    // End:0xA8
    if(Len(zzAdditionalName) > 0)
    {
        zzfullNameString = ((zzfullNameString $ " (") $ zzAdditionalName) $ ")";
    }
    // End:0xCC
    if(Len(zzfullNameString) > 28)
    {
        zzfullNameString = Left(zzfullNameString, 28) $ "...";
    }
    // End:0x121
    if(zzitemIndex == 0)
    {
        TreeClear("QuitReportWnd.ItemList");
        TreeInsertRootNode("QuitReportWnd.ItemList", "ItemList", "", 0, 0);
    }
    zzstrRetName = TreeInsertItemTooltipSimpleNode("QuitReportWnd.ItemList", string(zzitemIndex), "ItemList", 0, 0, 38, 5, 30, 38, ((zzfullNameString $ " (") $ string(Info.ItemNum)) $ ")");
    // End:0x1CF
    if((float(zzitemIndex) % float(2)) == float(0))
    {
        xxstx2k23("QuitReportWnd.ItemList", zzstrRetName, "L2UI_CH3.Null", 262, 38);        
    }
    else
    {
        xxstx2k23("QuitReportWnd.ItemList", zzstrRetName, "L2UI_CH3.etc.GroupBox_df_LineBack", 262, 38);
    }
    xxstx2k23("QuitReportWnd.ItemList", zzstrRetName, "L2UI_CH3.InventoryWnd.ItemWindow_DF_Slotbox_2x2", 36, 36, -260, 2);
    xxstx2k23("QuitReportWnd.ItemList", zzstrRetName, Info.IconName, 32, 32, -34, 3);
    xxStxXml("QuitReportWnd.ItemList", zzstrRetName, zzfullNameString, 7, 12, 0, true);
    // End:0x32D
    if(IsStackableItem(Info.ConsumeType))
    {
        // End:0x318
        if(Info.ItemNum > 9999)
        {
            zzitemNumEasyRead = "9999+";            
        }
        else
        {
            zzitemNumEasyRead = string(Info.ItemNum);
        }        
    }
    GetTextSize(zzfullNameString, zztxtWidth, zztxtHeight);
    xxStxXml("QuitReportWnd.ItemList", zzstrRetName, zzitemNumEasyRead, 180 - zztxtWidth, 12, 0, true);
    zzitemIndex++;
